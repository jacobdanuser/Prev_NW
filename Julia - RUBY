+"""
+Platform Capability Booster
+
+A generic script that evaluates and boosts platform capabilities across
+core dimensions (performance, reliability, security, scalability,
+maintainability, and observability).
+
+Usage:
+  python platform_capability_booster.py --platform "My Platform"
+  python platform_capability_booster.py --input platform.json --output boosted.json
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Dict, List, Tuple
+import argparse
+import json
+
+
+CapabilityMap = Dict[str, float]
+
+
+DEFAULT_CAPABILITIES: CapabilityMap = {
+    "performance": 45.0,
+    "reliability": 50.0,
+    "security": 40.0,
+    "scalability": 35.0,
+    "maintainability": 55.0,
+    "observability": 30.0,
+}
+
+
+@dataclass
+class BoostPlan:
+    platform_name: str
+    baseline: CapabilityMap
+    boosted: CapabilityMap
+    score_before: float
+    score_after: float
+    recommendations: List[str]
+
+
+def clamp(value: float, lower: float = 0.0, upper: float = 100.0) -> float:
+    """Clamp numeric value to capability score bounds."""
+    return max(lower, min(upper, value))
+
+
+def normalize_capabilities(capabilities: CapabilityMap) -> CapabilityMap:
+    """Normalize input capabilities and ensure all required dimensions exist."""
+    normalized = dict(DEFAULT_CAPABILITIES)
+    for key, value in capabilities.items():
+        if key in normalized:
+            normalized[key] = clamp(float(value))
+    return normalized
+
+
+def capability_score(capabilities: CapabilityMap) -> float:
+    """Compute an aggregate platform capability score."""
+    return sum(capabilities.values()) / len(capabilities)
+
+
+def derive_recommendations(capabilities: CapabilityMap) -> List[str]:
+    """Generate practical recommendations for weakest capability areas."""
+    ordered = sorted(capabilities.items(), key=lambda item: item[1])
+    weakest = ordered[:3]
+    recommendations: List[str] = []
+
+    playbooks: Dict[str, str] = {
+        "performance": "Introduce profiling, caching, and query/index optimization.",
+        "reliability": "Add health checks, retries with backoff, and chaos testing.",
+        "security": "Enable strict authN/authZ, dependency scanning, and secrets rotation.",
+        "scalability": "Adopt autoscaling, queue-based workloads, and horizontal partitioning.",
+        "maintainability": "Increase test coverage, enforce linting, and modularize components.",
+        "observability": "Add metrics, tracing, structured logging, and SLO dashboards.",
+    }
+
+    for dimension, score in weakest:
+        advice = playbooks.get(dimension, "Define and execute a focused improvement plan.")
+        recommendations.append(
+            f"{dimension.title()} ({score:.1f}/100): {advice}"
+        )
+
+    return recommendations
+
+
+def boost_capabilities(capabilities: CapabilityMap, intensity: float = 1.0) -> CapabilityMap:
+    """Boost weaker dimensions more aggressively while preserving balance.
+
+    intensity: 0.1 to 2.0. Higher means stronger optimization push.
+    """
+    intensity = clamp(intensity, 0.1, 2.0)
+    boosted: CapabilityMap = {}
+
+    for dimension, score in capabilities.items():
+        # Inverse scaling: weaker dimensions receive larger uplift.
+        weakness_factor = (100.0 - score) / 100.0
+        uplift = (8.0 + 22.0 * weakness_factor) * intensity
+        boosted[dimension] = clamp(score + uplift)
+
+    return boosted
+
+
+def build_boost_plan(
+    platform_name: str,
+    capabilities: CapabilityMap,
+    intensity: float = 1.0,
+) -> BoostPlan:
+    """Build a full before/after enhancement plan for a platform."""
+    baseline = normalize_capabilities(capabilities)
+    boosted = boost_capabilities(baseline, intensity=intensity)
+
+    return BoostPlan(
+        platform_name=platform_name,
+        baseline=baseline,
+        boosted=boosted,
+        score_before=capability_score(baseline),
+        score_after=capability_score(boosted),
+        recommendations=derive_recommendations(baseline),
+    )
+
+
+def to_serializable(plan: BoostPlan) -> Dict[str, object]:
+    """Convert plan dataclass to JSON-safe shape."""
+    delta: Dict[str, float] = {
+        key: round(plan.boosted[key] - plan.baseline[key], 2)
+        for key in plan.baseline
+    }
+
+    return {
+        "platform": plan.platform_name,
+        "score_before": round(plan.score_before, 2),
+        "score_after": round(plan.score_after, 2),
+        "net_gain": round(plan.score_after - plan.score_before, 2),
+        "baseline": {k: round(v, 2) for k, v in plan.baseline.items()},
+        "boosted": {k: round(v, 2) for k, v in plan.boosted.items()},
+        "delta": delta,
+        "recommendations": plan.recommendations,
+    }
+
+
+def load_input(path: str) -> Tuple[str, CapabilityMap, float]:
+    """Load platform profile from JSON file."""
+    with open(path, "r", encoding="utf-8") as file:
+        payload = json.load(file)
+
+    platform_name = str(payload.get("platform", "Unnamed Platform"))
+    capabilities = dict(payload.get("capabilities", {}))
+    intensity = float(payload.get("intensity", 1.0))
+
+    return platform_name, capabilities, intensity
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser(description="Boost the capabilities of any platform.")
+    parser.add_argument("--platform", default="Universal Platform", help="Platform display name.")
+    parser.add_argument(
+        "--input",
+        help="Optional JSON file with keys: platform, capabilities, intensity.",
+    )
+    parser.add_argument("--output", help="Optional path to write JSON output.")
+    parser.add_argument(
+        "--intensity",
+        type=float,
+        default=1.0,
+        help="Boost intensity in range 0.1 to 2.0.",
+    )
+    args = parser.parse_args()
+
+    if args.input:
+        platform_name, capabilities, intensity = load_input(args.input)
+    else:
+        platform_name, capabilities, intensity = args.platform, {}, args.intensity
+
+    plan = build_boost_plan(platform_name, capabilities, intensity=intensity)
+    output = to_serializable(plan)
+
+    rendered = json.dumps(output, indent=2)
+    print(rendered)
+
+    if args.output:
+        with open(args.output, "w", encoding="utf-8") as file:
+            file.write(rendered + "\n")
+
+
+if __name__ == "__main__":
+    main()

