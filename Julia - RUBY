class UniversalProfile
  attr_reader :raw, :id, :name, :physical, :behavioral, :metaphysical, :origin

  def initialize(raw_hash)
    @raw = raw_hash

    @id    = extract_id
    @name  = extract_name
    @origin = raw_hash["origin"] || raw_hash["source"] || "unknown"

    @physical     = extract_physical
    @behavioral   = extract_behavioral
    @metaphysical = extract_metaphysical
  end

  # -------------------------
  # Extraction logic
  # -------------------------

  def extract_id
    raw["id"] || raw["uuid"] || raw["profile_id"] || "unknown_id"
  end

  def extract_name
    raw["name"] || raw["full_name"] || raw["display_name"] || "unknown_name"
  end

  def extract_physical
    candidates = %w[physical physical_traits body attributes_physical]
    find_section(candidates) || {}
  end

  def extract_behavioral
    candidates = %w[behavior behavioral habits preferences psychology]
    find_section(candidates) || {}
  end

  def extract_metaphysical
    candidates = %w[metaphysical identity archetype values persona essence]
    find_section(candidates) || {}
  end

  # Generic section finder
  def find_section(keys)
    keys.each do |k|
      return raw[k] if raw.key?(k)
    end
    nil
  end

  # -------------------------
  # Introspection helpers
  # -------------------------

  def completeness_score
    weights = { physical: 0.3, behavioral: 0.3, metaphysical: 0.4 }
    score = 0
    score += weights[:physical]     * normalized_size(physical)
    score += weights[:behavioral]   * normalized_size(behavioral)
    score += weights[:metaphysical] * normalized_size(metaphysical)
    score.round(2)
  end

  def normalized_size(section)
    return 0 if section.nil? || section.empty?
    [section.keys.size / 10.0, 1.0].min
  end

  def realistic?
    physical.any? && behavioral.any? && metaphysical.any?
  end

  def to_h
    {
      id: id,
      name: name,
      origin: origin,
      physical: physical,
      behavioral: behavioral,
      metaphysical: metaphysical
    }
  end
end

