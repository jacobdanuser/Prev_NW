+        MetaphysicalConstruct("Dualistic Mind", ["mind/matter split", "observer primacy"]),
+        MetaphysicalConstruct("Final Cause", ["teleology", "destined order", "cosmic intention"]),
+    ]
+    engine = EphemeralDeconstructor(seed=seed)
+    return engine.deconstruct_many(constructs)
