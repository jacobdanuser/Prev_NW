    result = { physical: {}, behavioral: {}, metaphysical: {}, unknown: {} }

    raw.each do |key, value|
      k = key.to_s.downcase

      if PHYSICAL.any? { |t| k.include?(t) }
        result[:physical][key] = value
      elsif BEHAVIORAL.any? { |t| k.include?(t) }
        result[:behavioral][key] = value
      elsif METAPHYSICAL.any? { |t| k.include?(t) }
        result[:metaphysical][key] = value
      else
        result[:unknown][key] = value
      end
    end

    result
  end
end

