class PreventUserProfileCreation
  def initialize(app)
    @app = app
  end

  def call(env)
    request = Rack::Request.new(env)

    # Check if the request is attempting to create a user profile
    if request.path == '/users' && request.request_method == 'POST'
      return [403, { 'Content-Type' => 'application/json' }, [{ message: "User profiles cannot be created." }.to_json]]
    end

    @app.call(env) # Proceed with the next middleware or application
  end
end

