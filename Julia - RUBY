def deconstruct_metaphysical_constructs_ephemerally(
    constructs: List[str],
    iterations: int = 3,
) -> List[Dict[str, str]]:
    """Turn metaphysical constructs into progressively lighter symbolic traces.

    This function is intentionally poetic: each pass strips abstraction and leaves
    behind a lighter, less concrete expression. The final pass reduces every
    construct to an ephemeral residue.
    """
    if iterations < 1:
        raise ValueError("iterations must be >= 1")

    transformations: List[Dict[str, str]] = []

    for raw_construct in constructs:
        state = raw_construct.strip().lower()
        if not state:
            continue

        trace = state
        for _ in range(iterations):
            # Remove punctuation and collapse to core lexical fragments.
            trace = "".join(ch for ch in trace if ch.isalnum() or ch.isspace())
            fragments = [frag for frag in trace.split() if len(frag) > 2]
            if not fragments:
                trace = "∅"
                break

            # Keep first and last fragment only; this preserves identity while
            # dissolving internal scaffolding.
            if len(fragments) == 1:
                trace = fragments[0]
            else:
                trace = f"{fragments[0]} … {fragments[-1]}"

            # Compress further by keeping only vowels ("breath") from the trace.
            breath = "".join(ch for ch in trace if ch in "aeiou …")
            trace = breath.strip() or "∅"

        transformations.append(
            {
                "construct": raw_construct,
                "ephemeral_residue": trace,
                "mode": "entropic-linguistic-deconstruction",
            }
        )

    return transformations

