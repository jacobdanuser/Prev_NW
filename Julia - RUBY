+    """Render all constructs as an ephemeral deconstruction chant."""
+
+    engine = EphemeralDeconstructor()
+    blocks: List[str] = []
+
+    for construct in constructs:
+        frames = engine.deconstruct(construct)
+        stanza = [f"[{frame.phase}] {frame.residue}" for frame in frames]
+        blocks.append("\n".join(stanza))
+
