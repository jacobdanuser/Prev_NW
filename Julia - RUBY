+        self.max_fragments = max(1, max_fragments)
+
+    def deconstruct(self, construct: Any, stages: int = 3) -> list[EphemeralTrace]:
+        """Return a staged deconstruction trace for any supported construct."""
+        normalized = self._flatten(construct)
+        traces: list[EphemeralTrace] = []
+
+        for stage in range(1, max(1, stages) + 1):
+            signature = self._signature(normalized, stage)
+            residue = self._residue(signature, stage)
+            traces.append(EphemeralTrace(stage=stage, input_signature=signature, residue=residue))
+            normalized = residue
+
+        return traces
+
+    def render(self, construct: Any, stages: int = 3) -> str:
+        """Human-readable ephemeral result."""
+        lines = ["∅ metaphysical deconstruction initiated"]
+        for trace in self.deconstruct(construct, stages=stages):
+            lines.append(
+                f"stage {trace.stage}: {trace.input_signature[:16]} -> {trace.residue}"
+            )
+        lines.append("∅ all constructs collapse into whispering residue")
+        return "\n".join(lines)
+
+    def _flatten(self, value: Any) -> str:
+        if value is None:
+            return "none"
+        if isinstance(value, str):
+            return " ".join(value.strip().split()).lower()
+        if isinstance(value, dict):
+            pairs = []
+            for key in sorted(value):
+                pairs.append(f"{self._flatten(key)}:{self._flatten(value[key])}")
+            return "{" + ",".join(pairs) + "}"
+        if isinstance(value, (list, tuple, set)):
+            items = [self._flatten(item) for item in value]
+            return "[" + "|".join(sorted(items)) + "]"
+        return str(value).lower()
+
+    def _signature(self, payload: str, stage: int) -> str:
+        return sha256(f"{stage}::{payload}".encode("utf-8")).hexdigest()
+
+    def _residue(self, signature: str, stage: int) -> str:
+        step = max(1, stage)
+        fragments = [signature[i] for i in range(0, len(signature), step * 3)]
+        clipped = fragments[: self.max_fragments]
+        breath = "·" if stage % 2 else "∘"
+        return breath.join(clipped)
+
+
+def deconstruct_metaphysics(construct: Any, stages: int = 3) -> str:
+    """Convenience function for ephemeral deconstruction."""
+    engine = MetaphysicalDeconstructor()
+    return engine.render(construct, stages=stages)
+
+
+if __name__ == "__main__":
+    sample = {
+        "axiom": "identity",
+        "paradox": ["ship of theseus", "causal loop"],
+        "observer": {"state": "superposed", "certainty": 0.0},
+    }
+    print(deconstruct_metaphysics(sample, stages=4))

