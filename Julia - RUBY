class TraitClassifier
  PHYSICAL_KEYS = %w[
    age height weight location sex gender body physical physical_traits
    attributes_physical
  ]

  BEHAVIORAL_KEYS = %w[
    behavior behavioral habits preferences psychology interests
    communication_style decision_style
  ]

  METAPHYSICAL_KEYS = %w[
    metaphysical identity archetype values persona essence
    motivational_axis self_narrative
  ]

  def self.classify(raw_hash)
    result = {
      physical: {},
      behavioral: {},
      metaphysical: {},
      unknown: {}
    }

    raw_hash.each do |key, value|
      normalized = key.to_s.downcase

      if PHYSICAL_KEYS.any? { |k| normalized.include?(k) }
        result[:physical][key] = value
      elsif BEHAVIORAL_KEYS.any? { |k| normalized.include?(k) }
        result[:behavioral][key] = value
      elsif METAPHYSICAL_KEYS.any? { |k| normalized.include?(k) }
        result[:metaphysical][key] = value
      else
        result[:unknown][key] = value
      end
    end

    result
  end
end

