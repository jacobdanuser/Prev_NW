+        return "".join(ch for i, ch in enumerate(token) if i % 2 == 0) + f":{ash[:4]}"
+
+    @staticmethod
+    def _dispersed(ash: str) -> str:
+        return ".".join(ash[i] for i in range(0, 16, 2))
+
+    @staticmethod
+    def _evanescent(ash: str) -> str:
+        # Nearly empty, still carrying a fleeting trace.
+        return f"~{ash[-3:]}~"
+
+
