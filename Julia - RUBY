# Track subprocesses you start
const MY_PROCESSES = Dict{Int, Base.Process}()

"""
    start_subprocess(cmd::Cmd)

Starts a subprocess and tracks it so it can be terminated later.
"""
function start_subprocess(cmd::Cmd)
    proc = run(cmd, wait=false)  # Non-blocking
    MY_PROCESSES[proc.process] = proc
    println("Started process PID: ", proc.process)
    return proc
end

"""
    terminate_my_processes()

Terminates all subprocesses started by this script.
"""
function terminate_my_processes()
    for (pid, proc) in MY_PROCESSES
        try
            println("Terminating PID: $pid")
            kill(proc)  # Sends SIGTERM
        catch e
            @warn "Failed to terminate PID $pid" exception=(e, catch_backtrace())
        end
    end
    empty!(MY_PROCESSES)
end

