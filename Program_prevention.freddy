index 0000000000000000000000000000000000000000..8a297fa57e72dafaf8a9539bc13210c99faa6773
--- /dev/null
+++ b/test_channel_spawn_shutdown.py
@@ -0,0 +1,27 @@
+from channel_spawn_shutdown import SpawnScope, SpawnState, SpawnShutdownController
+
+
+def test_shutdown_communication_and_index_only():
+    controller = SpawnShutdownController()
+    comm = controller.register_creation("comm", SpawnScope.COMMUNICATION_CHANNEL)
+    idx = controller.register_creation("idx", SpawnScope.INDEX)
+    other = controller.register_creation("other", SpawnScope.OTHER)
+
+    result = controller.shutdown_communication_and_index("policy enforcement")
+
+    assert len(result[SpawnScope.COMMUNICATION_CHANNEL.value]) == 1
+    assert len(result[SpawnScope.INDEX.value]) == 1
+    assert comm.state == SpawnState.SHUTDOWN
+    assert idx.state == SpawnState.SHUTDOWN
+    assert other.state == SpawnState.RUNNING
+
+
+def test_shutdown_idempotent_for_already_stopped_entries():
+    controller = SpawnShutdownController()
+    controller.register_creation("comm", SpawnScope.COMMUNICATION_CHANNEL)
+
+    first = controller.shutdown_communication_and_index("policy enforcement")
+    second = controller.shutdown_communication_and_index("policy enforcement")
+
+    assert len(first[SpawnScope.COMMUNICATION_CHANNEL.value]) == 1
+    assert len(second[SpawnScope.COMMUNICATION_CHANNEL.value]) == 0
