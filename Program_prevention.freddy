 """
 Advanced Integration Guide
 Real-world patterns for using the metaphysical restriction system
 in games, stories, and theoretical models.
 """
 
+from dataclasses import dataclass
+from datetime import datetime
 from metaphysical_restrictions import (
     MetaphysicalPractitioner, MetaphysicalCapability,
     RestrictionRule, RestrictionType, CapabilityType,
     ConservationOfEnergyFramework, EntropicDecayFramework,
     CausalityFramework, ConsciousnessAnchorFramework
 )
 
 
+
+
+# ============================================================================
+# PATTERN 0: SPAWN SHUTDOWN GUARD
+# ============================================================================
+
+@dataclass
+class ProgramCreation:
+    """Represents a created program unit tracked by channel and index."""
+
+    program_id: str
+    channel: str
+    index_key: str
+    spawned: bool = True
+    active: bool = True
+    shutdown_reason: str = ""
+    shutdown_at: str | None = None
+
+
+class ChannelIndexShutdownManager:
+    """Shut down spawned program creations by communication channel or index."""
+
+    def __init__(self):
+        self._creations: dict[str, ProgramCreation] = {}
+
+    def register_creation(self, program_id: str, channel: str, index_key: str, *, spawned: bool = True) -> ProgramCreation:
+        """Track a newly created program instance."""
+        creation = ProgramCreation(
+            program_id=program_id,
+            channel=channel,
+            index_key=index_key,
+            spawned=spawned,
+        )
+        self._creations[program_id] = creation
+        return creation
+
+    def shutdown_spawned_in_channel(self, channel: str, reason: str = "channel_shutdown") -> list[ProgramCreation]:
+        """Deactivate all spawned creations in a communication channel."""
+        return self._shutdown_matching(
+            lambda creation: creation.spawned and creation.channel == channel,
+            reason=reason,
+        )
+
+    def shutdown_spawned_in_index(self, index_key: str, reason: str = "index_shutdown") -> list[ProgramCreation]:
+        """Deactivate all spawned creations associated with an index key."""
+        return self._shutdown_matching(
+            lambda creation: creation.spawned and creation.index_key == index_key,
+            reason=reason,
+        )
+
+    def list_active(self) -> list[ProgramCreation]:
+        """Return all active tracked creations."""
+        return [creation for creation in self._creations.values() if creation.active]
+
+    def _shutdown_matching(self, predicate, reason: str) -> list[ProgramCreation]:
+        shut_down: list[ProgramCreation] = []
+        timestamp = datetime.utcnow().isoformat(timespec="seconds") + "Z"
+
+        for creation in self._creations.values():
+            if creation.active and predicate(creation):
+                creation.active = False
+                creation.shutdown_reason = reason
+                creation.shutdown_at = timestamp
+                shut_down.append(creation)
+
+        return shut_down
+
+
 # ============================================================================
 # PATTERN 1: RPG SPELL SYSTEM
 # ============================================================================
 
 class RPGSpellSystem:
     """Integration pattern for traditional RPG magic systems (D&D-style)."""
     
     def __init__(self, player_name: str, spell_slots: int = 10):
         self.practitioner = MetaphysicalPractitioner(
             name=player_name,
             energy_pool=float(spell_slots * 10),
             max_energy=float(spell_slots * 10)
         )
         self.practitioner.add_framework(ConservationOfEnergyFramework(spell_slots * 10))
         self.spell_slots = spell_slots
         self.cast_history = []
     
     def add_spell(self, name: str, level: int, effect: str) -> MetaphysicalCapability:
         """Add a standard RPG spell to the spellbook."""
         # Spell power = spell level * 10
         spell = MetaphysicalCapability(
             name=name,
             capability_type=self._effect_to_capability(effect),
             base_power_level=float(level * 10)
         )
