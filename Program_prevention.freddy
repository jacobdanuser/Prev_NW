@@ -0,0 +1,125 @@
+"""Utilities to shut down spawned program creations by channel/index.
+
+This module provides a small in-memory control layer for systems that track
+"program creations" (subprocesses, jobs, workers) associated with a
+communication channel and/or index.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from datetime import datetime, timezone
+from enum import Enum
+from typing import Callable, Dict, Iterable, List, Optional, Tuple
+
+
+class ProgramState(str, Enum):
+    """Lifecycle state for a tracked program creation."""
+
+    RUNNING = "running"
+    STOPPED = "stopped"
+    FAILED = "failed"
+
+
+@dataclass
+class ProgramCreation:
+    """Represents a program creation that can be stopped."""
+
+    program_id: str
+    channel: str
+    index: Optional[str] = None
+    state: ProgramState = ProgramState.RUNNING
+    created_at: datetime = field(default_factory=lambda: datetime.now(timezone.utc))
+    stopped_at: Optional[datetime] = None
+    stop_reason: Optional[str] = None
+
+
+StopCallback = Callable[[ProgramCreation], Tuple[bool, str]]
+
+
+class ProgramCreationController:
+    """Tracks and force-stops running program creations by channel or index."""
+
+    def __init__(self, stop_callback: Optional[StopCallback] = None):
+        self._programs: Dict[str, ProgramCreation] = {}
+        self._stop_callback = stop_callback or self._default_stop
+
+    def register(self, program: ProgramCreation) -> None:
+        """Register or replace a tracked program creation."""
+        self._programs[program.program_id] = program
+
+    def list_running(self) -> List[ProgramCreation]:
+        """Return all currently running programs."""
+        return [p for p in self._programs.values() if p.state == ProgramState.RUNNING]
+
+    def shutdown_in_scope(
+        self,
+        *,
+        channel: Optional[str] = None,
+        index: Optional[str] = None,
+        reason: str = "policy_shutdown",
+    ) -> Dict[str, List[str]]:
+        """Stop running programs that match channel and/or index.
+
+        If both channel and index are provided, both must match.
+        If only one filter is provided, only that filter is applied.
+        """
+        if channel is None and index is None:
+            raise ValueError("channel or index must be provided")
+
+        candidates = [
+            p
+            for p in self.list_running()
+            if self._matches_scope(p, channel=channel, index=index)
+        ]
+
+        stopped: List[str] = []
+        failed: List[str] = []
+
+        for program in candidates:
+            ok, detail = self._stop_callback(program)
+            if ok:
+                program.state = ProgramState.STOPPED
+                program.stopped_at = datetime.now(timezone.utc)
+                program.stop_reason = reason
+                stopped.append(program.program_id)
+            else:
+                program.state = ProgramState.FAILED
+                program.stop_reason = f"{reason}:{detail}"
+                failed.append(program.program_id)
+
+        return {
+            "stopped": stopped,
+            "failed": failed,
+        }
+
+    @staticmethod
+    def _matches_scope(
+        program: ProgramCreation,
+        *,
+        channel: Optional[str],
+        index: Optional[str],
+    ) -> bool:
+        channel_match = True if channel is None else program.channel == channel
+        index_match = True if index is None else program.index == index
+        return channel_match and index_match
+
+    @staticmethod
+    def _default_stop(program: ProgramCreation) -> Tuple[bool, str]:
+        # In production, replace with termination logic (pid kill, task cancel, etc.).
+        return True, "stopped"
+
+
+def shutdown_program_creations(
+    programs: Iterable[ProgramCreation],
+    *,
+    channel: Optional[str] = None,
+    index: Optional[str] = None,
+    reason: str = "policy_shutdown",
+    stop_callback: Optional[StopCallback] = None,
+) -> Dict[str, List[str]]:
+    """Convenience function for one-shot shutdown operations."""
+    controller = ProgramCreationController(stop_callback=stop_callback)
+    for program in programs:
+        controller.register(program)
+    return controller.shutdown_in_scope(channel=channel, index=index, reason=reason)
