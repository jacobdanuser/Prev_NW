from pathlib import Path

COMMON_SPOOFED = {
    "svchost.exe",
    "explorer.exe",
    "lsass.exe",
    "csrss.exe",
    "winlogon.exe",
    "services.exe",
    "smss.exe",
}

SUSPICIOUS_ROOTS = [
    r"C:\Users",
    r"C:\ProgramData",
    r"C:\Temp",
]

def find_suspicious_exes():
    suspicious = []
    for root in SUSPICIOUS_ROOTS:
        root_path = Path(root)
        if not root_path.exists():
            continue

        for dirpath, dirnames, filenames in os.walk(root_path):
            for f in filenames:
                if f.lower().endswith(".exe"):
                    full_path = Path(dirpath) / f
                    if f.lower() in COMMON_SPOOFED:
                        suspicious.append(str(full_path))
    return suspicious

if __name__ == "__main__":
    suspects = find_suspicious_exes()
    print("Suspicious executables (by name/location):")
    for s in suspects:
        print(" -", s)
