import psutil
from pathlib import Path
import csv
import os

COMMON_SPOOFED = {
    "svchost.exe",
    "explorer.exe",
    "lsass.exe",
    "csrss.exe",
    "winlogon.exe",
    "services.exe",
    "smss.exe",
}

def is_in_system32(path: Path) -> bool:
    try:
        return str(path).lower().startswith(r"c:\windows\system32")
    except Exception:
        return False

def is_in_windows_dir(path: Path) -> bool:
    try:
        return str(path).lower().startswith(r"c:\windows")
    except Exception:
        return False

def is_in_suspicious_user_area(path: Path) -> bool:
    p = str(path).lower()
    return (
        r"\temp\" in p
        or r"\appdata\local\" in p
        or r"\appdata\roaming\" in p
    )

def main():
    suspicious = []

    for proc in psutil.process_iter(["pid", "name", "exe"]):
        try:
            name = (proc.info["name"] or "").lower()
            exe = proc.info["exe"]
            if not exe:
                continue

            exe_path = Path(exe)
            spoofed_name = name in COMMON_SPOOFED
            in_system32 = is_in_system32(exe_path)
            in_windows = is_in_windows_dir(exe_path)
            in_suspicious_area = is_in_suspicious_user_area(exe_path)

            looks_suspicious = False

            # 1) Spoofed name but not in System32
            if spoofed_name and not in_system32:
                looks_suspicious = True

            # 2) Any executable in temp/appdata areas
            if in_suspicious_area:
                looks_suspicious = True

            if looks_suspicious:
                suspicious.append({
                    "name": name,
                    "pid": proc.info["pid"],
                    "path": str(exe_path),
                    "spoofed_name": spoofed_name,
                    "in_system32": in_system32,
                    "in_windows_dir": in_windows,
                    "in_suspicious_user_area": in_suspicious_area,
                })

        except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
            continue

    desktop = Path(os.path.expanduser("~")) / "Desktop"
    desktop.mkdir(parents=True, exist_ok=True)
    out_file = desktop / "suspicious_processes_report.csv"

    with out_file.open("w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(
            f,
            fieldnames=[
                "name",
                "pid",
                "path",
                "spoofed_name",
                "in_system32",
                "in_windows_dir",
                "in_suspicious_user_area",
            ],
        )
        writer.writeheader()
        writer.writerows(suspicious)

    print(f"Found {len(suspicious)} suspicious processes.")
    print(f"Report saved to: {out_file}")

if __name__ == "__main__":
    main()
