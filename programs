from pathlib import Path
import hashlib
import datetime
import os

# === CONFIGURATION ===

# Add trusted executable paths here
TRUSTED = {
    r"C:\Windows\System32\svchost.exe",
    r"C:\Windows\explorer.exe",
    r"C:\Program Files\Google\Chrome\Application\chrome.exe",
}

COMMON_SPOOFED = {
    "svchost.exe",
    "explorer.exe",
    "lsass.exe",
    "csrss.exe",
    "winlogon.exe",
    "services.exe",
    "smss.exe",
}

LOG_FILE = Path("system_guardian_log.txt")

# === UTILITY FUNCTIONS ===

def log(message):
    timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with LOG_FILE.open("a", encoding="utf-8") as f:
        f.write(f"[{timestamp}] {message}\n")
    print(message)

def file_hash(path):
    try:
        h = hashlib.sha256()
        with open(path, "rb") as f:
            for chunk in iter(lambda: f.read(4096), b""):
                h.update(chunk)
        return h.hexdigest()
    except Exception:
        return None

def suspicious_location(path: Path) -> bool:
    p = str(path).lower()
    return (
        r"\temp\" in p
        or r"\appdata\local\" in p
        or r"\appdata\roaming\" in p
        or r"\programdata\" in p
    )

# === MAIN ANALYSIS ===

def analyze_process(proc):
    try:
        name = (proc.name() or "").lower()
        exe = proc.exe()
        if not exe:
            return None

        exe_path = Path(exe)
        reasons = []

        # Allow-list enforcement
        if str(exe_path) not in TRUSTED:
            reasons.append("Executable not in trusted allow-list")

        # Suspicious behavior checks
        if name in COMMON_SPOOFED and "system32" not in str(exe_path).lower():
            reasons.append("System-like name outside System32")

        if suspicious_location(exe_path):
            reasons.append("Running from suspicious directory")

        if reasons:
            return {
                "pid": proc.pid,
                "name": name,
                "path": str(exe_path),
                "reasons": reasons,
                "hash": file_hash(exe_path)
            }

    except (psutil.NoSuchProcess, psutil.AccessDenied):
        return None

def main():
    log("=== System Guardian started ===")

    seen = set()

    while True:
        for proc in psutil.process_iter(["pid", "name", "exe"]):
            result = analyze_process(proc)
            if result and result["pid"] not in seen:
                seen.add(result["pid"])

                log("\n[!] Untrusted or suspicious process detected:")
                log(f"    Name: {result['name']}")
                log(f"    PID: {result['pid']}")
                log(f"    Path: {result['path']}")
                log(f"    Reasons: {', '.join(result['reasons'])}")
                log(f"    SHA-256: {result['hash']}")

                choice = input(f"Terminate PID {result['pid']}? (y/n): ").strip().lower()
                if choice == "y":
                    try:
                        psutil.Process(result["pid"]).terminate()
                        log(f"[+] Process {result['pid']} terminated.")
                    except Exception as e:
                        log(f"[!] Failed to terminate: {e}")

        time.sleep(3)

if __name__ == "__main__":
    main()
