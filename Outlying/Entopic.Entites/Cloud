+def take_baseline(system: ManagedSystem, cfg: GuardConfig, state_dir: pathlib.Path) -> None:
+    manifest_path, snapshot_path = state_paths(state_dir, system)
+    manifest_path.parent.mkdir(parents=True, exist_ok=True)
+
+    manifest = {
+        "generated_at": now_iso(),
+        "system": system.name,
+        "path": str(system.path),
+        "files": build_manifest(system.path, cfg.ignore_globs, system.include_hidden),
+    }
+    manifest_path.write_text(json.dumps(manifest, indent=2), encoding="utf-8")
+
+    with tarfile.open(snapshot_path, "w:gz") as tar:
+        tar.add(system.path, arcname=".")
+
+
+def restore_from_snapshot(system: ManagedSystem, state_dir: pathlib.Path) -> None:
+    _, snapshot = state_paths(state_dir, system)
+    if not snapshot.exists():
+        raise FileNotFoundError(f"No snapshot found for {system.name}: {snapshot}")
+
+    with tempfile.TemporaryDirectory(prefix=f"rewrite-guard-{system.name}-") as tmp:
+        temp_dir = pathlib.Path(tmp)
+        with tarfile.open(snapshot, "r:gz") as tar:
+            tar.extractall(temp_dir)
+
+        # Clear existing content, then restore.
+        for child in system.path.iterdir():
+            if child.is_dir():
+                shutil.rmtree(child)
+            else:
+                child.unlink()
+
+        for restored in temp_dir.iterdir():
+            target = system.path / restored.name
+            shutil.move(str(restored), str(target))
+
+
+def detect_drift(system: ManagedSystem, cfg: GuardConfig, state_dir: pathlib.Path) -> dict:
+    manifest_path, _ = state_paths(state_dir, system)
+    if not manifest_path.exists():
+        raise FileNotFoundError(
+            f"No baseline manifest for {system.name}. Run init-baseline first."
+        )
+
+    baseline = json.loads(manifest_path.read_text())
+    current_files = build_manifest(system.path, cfg.ignore_globs, system.include_hidden)
+    baseline_files = baseline["files"]
+
+    missing = sorted(set(baseline_files) - set(current_files))
+    extra = sorted(set(current_files) - set(baseline_files))
+
+    changed = []
+    for rel in sorted(set(current_files) & set(baseline_files)):
+        if current_files[rel]["sha256"] != baseline_files[rel]["sha256"]:
+            changed.append(rel)
+
+    git_ok = True
+    git_reasons: list[str] = []
+    if (system.path / ".git").exists():
+        git_ok, git_reasons = verify_repo_trust(system.path, cfg)
+
+    return {
+        "missing": missing,
+        "extra": extra,
+        "changed": changed,
+        "git_trusted": git_ok,
+        "git_reasons": git_reasons,
+    }
+
+
+def scan_once(cfg: GuardConfig, state_dir: pathlib.Path, repair: bool) -> int:
+    state_dir.mkdir(parents=True, exist_ok=True)
+    incidents = 0
+
+    for system in cfg.systems:
+        drift = detect_drift(system, cfg, state_dir)
+        has_drift = bool(drift["missing"] or drift["extra"] or drift["changed"])
+        trusted = drift["git_trusted"]
+
+        event = {
+            "time": now_iso(),
+            "system": system.name,
+            "path": str(system.path),
+            "drift": drift,
+            "action": "none",
+        }
+
+        if has_drift or not trusted:
+            incidents += 1
+            if repair:
+                restore_from_snapshot(system, state_dir)
+                event["action"] = "restored_snapshot"
+            else:
+                event["action"] = "detected_only"
+
+        write_audit(state_dir, event)
+        print(json.dumps(event, indent=2))
+
+    return incidents
+
