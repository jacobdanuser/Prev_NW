#!/usr/bin/env python3
from pathlib import Path
import re

# Map old module paths -> new module paths
REWRITE_MAP = {
    "old_pkg.utils": "new_pkg.core.utils",
    "old_pkg.models": "new_pkg.domain.models",
}

PY_FILE = re.compile(r".*\.py$")

def rewrite_imports(text: str) -> str:
    for old, new in REWRITE_MAP.items():
        text = re.sub(rf"(^|\n)\s*import\s+{re.escape(old)}(\s|$)", rf"\1import {new}\2", text)
        text = re.sub(rf"(^|\n)\s*from\s+{re.escape(old)}\s+import\s+", rf"\1from {new} import ", text)
    return text

def main(root: str = "."):
    root_path = Path(root)
    for p in root_path.rglob("*"):
        if p.is_file() and PY_FILE.match(str(p)):
            original = p.read_text(encoding="utf-8")
            updated = rewrite_imports(original)
            if updated != original:
                p.write_text(updated, encoding="utf-8")
                print(f"rewrote: {p}")

if __name__ == "__main__":
    main(".")
