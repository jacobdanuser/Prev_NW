+#!/usr/bin/env python3
+"""System Change Reverter
+
+Defensive utility to detect and roll back unapproved changes in a Git repository.
+
+Threat model addressed:
+- Unauthorized or unexpected local file changes.
+- Untrusted commits introduced from sync operations.
+- Drift from a known-good baseline commit.
+
+This tool is intended for defensive administration on systems you own.
+"""
+
+from __future__ import annotations
+
+import argparse
+import dataclasses
+import hashlib
+import json
+import os
+import subprocess
+import sys
+import time
+from pathlib import Path
+from typing import Iterable
+
+
+class ReverterError(RuntimeError):
+    """Raised when a repository check or restore action fails."""
+
+
+@dataclasses.dataclass(frozen=True)
+class FileRecord:
+    path: str
+    sha256: str
+    mode: int
+
+
+@dataclasses.dataclass
+class Snapshot:
+    repo: str
+    baseline_commit: str
+    created_unix: int
+    files: list[FileRecord]
+
+    def to_json(self) -> str:
+        payload = {
+            "repo": self.repo,
+            "baseline_commit": self.baseline_commit,
+            "created_unix": self.created_unix,
+            "files": [dataclasses.asdict(record) for record in self.files],
+        }
+        return json.dumps(payload, indent=2, sort_keys=True)
+
+    @classmethod
+    def from_json(cls, text: str) -> "Snapshot":
+        payload = json.loads(text)
+        files = [FileRecord(**record) for record in payload["files"]]
+        return cls(
+            repo=payload["repo"],
+            baseline_commit=payload["baseline_commit"],
+            created_unix=payload["created_unix"],
+            files=files,
+        )
+
+
+def run_git(repo: Path, args: list[str], check: bool = True) -> str:
+    command = ["git", "-C", str(repo), *args]
+    process = subprocess.run(command, text=True, capture_output=True)
+    if check and process.returncode != 0:
+        raise ReverterError(f"git command failed: {' '.join(command)}\n{process.stderr.strip()}")
+    return process.stdout.strip()
+
+
+def ensure_git_repo(repo: Path) -> None:
+    marker = run_git(repo, ["rev-parse", "--is-inside-work-tree"])
+    if marker != "true":
+        raise ReverterError(f"Not a git work tree: {repo}")
+
+
+def iter_tracked_files(repo: Path) -> Iterable[Path]:
+    output = run_git(repo, ["ls-files", "-z"])
+    if not output:
+        return []
+    return [repo / rel for rel in output.split("\0") if rel]
+
+
+def hash_file(path: Path) -> str:
+    hasher = hashlib.sha256()
+    with path.open("rb") as handle:
+        while True:
+            chunk = handle.read(1024 * 1024)
+            if not chunk:
+                break
+            hasher.update(chunk)
+    return hasher.hexdigest()
+
+
+def create_snapshot(repo: Path) -> Snapshot:
+    ensure_git_repo(repo)
+    commit = run_git(repo, ["rev-parse", "HEAD"])
+    records: list[FileRecord] = []
+    for path in iter_tracked_files(repo):
+        if not path.exists():
+            continue
+        mode = path.stat().st_mode & 0o777
+        records.append(FileRecord(path=str(path.relative_to(repo)), sha256=hash_file(path), mode=mode))
+    return Snapshot(
+        repo=str(repo.resolve()),
+        baseline_commit=commit,
+        created_unix=int(time.time()),
+        files=sorted(records, key=lambda item: item.path),
+    )
+
+
+def load_snapshot(path: Path) -> Snapshot:
+    return Snapshot.from_json(path.read_text(encoding="utf-8"))
+
+
+def save_snapshot(snapshot: Snapshot, path: Path) -> None:
+    path.write_text(snapshot.to_json() + "\n", encoding="utf-8")
+
+
+def compare_with_snapshot(repo: Path, snapshot: Snapshot) -> dict[str, list[str]]:
+    ensure_git_repo(repo)
+    expected = {record.path: record for record in snapshot.files}
+    actual: dict[str, FileRecord] = {}
+
+    for path in iter_tracked_files(repo):
+        if path.exists():
+            rel = str(path.relative_to(repo))
+            actual[rel] = FileRecord(path=rel, sha256=hash_file(path), mode=path.stat().st_mode & 0o777)
+
+    added = sorted(set(actual) - set(expected))
+    removed = sorted(set(expected) - set(actual))
+
+    modified = sorted(
+        [
+            rel
+            for rel in sorted(set(actual) & set(expected))
+            if actual[rel].sha256 != expected[rel].sha256 or actual[rel].mode != expected[rel].mode
+        ]
+    )
+    return {"added": added, "removed": removed, "modified": modified}
+
+
+def print_drift(drift: dict[str, list[str]]) -> None:
+    for category in ("added", "removed", "modified"):
+        print(f"{category}: {len(drift[category])}")
+        for item in drift[category]:
+            print(f"  - {item}")
+
+
+def restore_to_snapshot(repo: Path, snapshot: Snapshot, dry_run: bool = False) -> None:
+    drift = compare_with_snapshot(repo, snapshot)
+    if all(not drift[key] for key in drift):
+        print("No drift detected; repository already matches snapshot.")
+        return
+
+    print("Drift detected:")
+    print_drift(drift)
+
+    if dry_run:
+        print("Dry-run enabled: no changes applied.")
+        return
+
+    run_git(repo, ["reset", "--hard", snapshot.baseline_commit])
+    run_git(repo, ["clean", "-fd"])
+    print(f"Repository restored to snapshot baseline commit {snapshot.baseline_commit}.")
+
+
+def audit_history(
+    repo: Path,
+    trusted_authors: set[str],
+    since_ref: str | None,
+    max_commits: int,
+) -> int:
+    ensure_git_repo(repo)
+    rev_range = "HEAD"
+    if since_ref:
+        rev_range = f"{since_ref}..HEAD"
+
+    log_output = run_git(
+        repo,
+        [
+            "log",
+            rev_range,
+            f"--max-count={max_commits}",
+            "--pretty=format:%H%x1f%ae%x1f%an%x1f%s",
+        ],
+    )
+    if not log_output:
+        print("No commits found in requested range.")
+        return 0
+
+    suspicious = 0
+    for line in log_output.splitlines():
+        commit, email, author, subject = line.split("\x1f", 3)
+        trusted = email in trusted_authors if trusted_authors else True
+        badge = "OK" if trusted else "UNTRUSTED"
+        print(f"[{badge}] {commit[:10]} {author} <{email}> :: {subject}")
+        if not trusted:
+            suspicious += 1
+
+    if suspicious:
+        print(f"Found {suspicious} commit(s) by untrusted authors.")
+    else:
+        print("No untrusted authors found in scanned commits.")
+    return suspicious
+
+
+def parse_csv_set(raw: str | None) -> set[str]:
+    if not raw:
+        return set()
+    return {item.strip() for item in raw.split(",") if item.strip()}
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(
+        description=(
+            "Detect and rollback unapproved Git changes for defensive system hardening. "
+            "Use on repositories you control."
+        )
+    )
+    parser.add_argument("--repo", default=".", help="Path to target Git repository (default: current directory).")
+
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    init_cmd = sub.add_parser("init-snapshot", help="Create a known-good snapshot manifest.")
+    init_cmd.add_argument("--out", default=".guard_snapshot.json", help="Snapshot output path.")
+
+    check_cmd = sub.add_parser("check", help="Check repository drift against a snapshot.")
+    check_cmd.add_argument("--snapshot", default=".guard_snapshot.json", help="Snapshot JSON path.")
+
+    restore_cmd = sub.add_parser("restore", help="Restore repository to snapshot baseline commit.")
+    restore_cmd.add_argument("--snapshot", default=".guard_snapshot.json", help="Snapshot JSON path.")
+    restore_cmd.add_argument("--dry-run", action="store_true", help="Show changes without restoring.")
+
+    audit_cmd = sub.add_parser("audit-history", help="List commits and flag untrusted authors.")
+    audit_cmd.add_argument(
+        "--trusted-authors",
+        default="",
+        help="Comma-separated list of trusted author emails. Empty => trust all authors.",
+    )
+    audit_cmd.add_argument("--since-ref", default=None, help="Scan commit range since this reference.")
+    audit_cmd.add_argument("--max-commits", type=int, default=250, help="Maximum commits to scan.")
+
+    return parser.parse_args()
+
+
+def main() -> int:
+    args = parse_args()
+    repo = Path(args.repo).resolve()
+
+    try:
+        if args.command == "init-snapshot":
+            snapshot = create_snapshot(repo)
+            save_snapshot(snapshot, Path(args.out))
+            print(f"Snapshot written to {args.out} at baseline {snapshot.baseline_commit}")
+            return 0
+
+        if args.command == "check":
+            snapshot = load_snapshot(Path(args.snapshot))
+            drift = compare_with_snapshot(repo, snapshot)
+            print_drift(drift)
+            return 1 if any(drift[key] for key in drift) else 0
+
+        if args.command == "restore":
+            snapshot = load_snapshot(Path(args.snapshot))
+            restore_to_snapshot(repo, snapshot, dry_run=args.dry_run)
+            return 0
+
+        if args.command == "audit-history":
+            trusted = parse_csv_set(args.trusted_authors)
+            suspicious = audit_history(
+                repo=repo,
+                trusted_authors=trusted,
+                since_ref=args.since_ref,
+                max_commits=args.max_commits,
+            )
+            return 1 if suspicious else 0
+
+        raise ReverterError(f"Unknown command: {args.command}")
+    except ReverterError as exc:
+        print(f"ERROR: {exc}", file=sys.stderr)
+        return 2
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
