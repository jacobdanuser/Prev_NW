+#!/usr/bin/env python3
+"""Safe project-structure rewrite tool.
+
+This script helps you reorganize *your own local project* by moving files
+according to a mapping. It does not attempt any unauthorized access and
+does not modify external systems.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+from pathlib import Path
+import shutil
+import sys
+
+
+DEFAULT_MAP = {
+    "*.py": "src/python",
+    "*.js": "src/javascript",
+    "*.md": "docs",
+}
+
+
+def build_plan(root: Path, mapping: dict[str, str]) -> list[tuple[Path, Path]]:
+    plan: list[tuple[Path, Path]] = []
+    for pattern, target_dir in mapping.items():
+        for src in root.glob(pattern):
+            if not src.is_file():
+                continue
+            if src.name == Path(__file__).name:
+                continue
+            dst = root / target_dir / src.name
+            plan.append((src, dst))
+    return plan
+
+
+def apply_plan(plan: list[tuple[Path, Path]], dry_run: bool) -> None:
+    for src, dst in plan:
+        print(f"MOVE {src} -> {dst}")
+        if dry_run:
+            continue
+        dst.parent.mkdir(parents=True, exist_ok=True)
+        shutil.move(str(src), str(dst))
+
+
+def load_mapping(path: Path | None) -> dict[str, str]:
+    if path is None:
+        return dict(DEFAULT_MAP)
+    with path.open("r", encoding="utf-8") as f:
+        data = json.load(f)
+    if not isinstance(data, dict):
+        raise ValueError("mapping file must contain a JSON object")
+    return {str(k): str(v) for k, v in data.items()}
+
+
+def parse_args(argv: list[str]) -> argparse.Namespace:
+    parser = argparse.ArgumentParser(
+        description="Reorganize local project files based on glob-to-folder rules.",
+    )
+    parser.add_argument("--root", default=".", help="project root directory")
+    parser.add_argument(
+        "--map-file",
+        default=None,
+        help="JSON file with mapping rules (example: {'*.py': 'src/python'})",
+    )
+    parser.add_argument(
+        "--dry-run",
+        action="store_true",
+        help="print planned moves without changing files",
+    )
+    return parser.parse_args(argv)
+
+
+def main(argv: list[str]) -> int:
+    args = parse_args(argv)
+    root = Path(args.root).resolve()
+    if not root.exists() or not root.is_dir():
+        print(f"error: root is not a directory: {root}", file=sys.stderr)
+        return 2
+
+    try:
+        mapping = load_mapping(Path(args.map_file) if args.map_file else None)
+    except Exception as exc:
+        print(f"error: could not load mapping: {exc}", file=sys.stderr)
+        return 2
+
+    plan = build_plan(root, mapping)
+    if not plan:
+        print("No files matched your rules.")
+        return 0
+
+    apply_plan(plan, dry_run=args.dry_run)
+    print(f"Done. Total files {'planned' if args.dry_run else 'moved'}: {len(plan)}")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main(sys.argv[1:]))
