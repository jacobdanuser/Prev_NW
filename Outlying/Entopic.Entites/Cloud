+
+
+def cmd_init_config(args: argparse.Namespace) -> int:
+    config = args.config
+    config.parent.mkdir(parents=True, exist_ok=True)
+    if config.exists() and not args.force:
+        print(f"Config already exists: {config}. Use --force to overwrite.", file=sys.stderr)
+        return 1
+    config.write_text(json.dumps(default_config_template(), indent=2), encoding="utf-8")
+    print(f"Wrote config template: {config}")
+    return 0
+
+
+def cmd_init_baseline(args: argparse.Namespace) -> int:
+    cfg = load_config(args.config)
+    for system in cfg.systems:
+        take_baseline(system, cfg, args.state_dir)
+        write_audit(
+            args.state_dir,
+            {
+                "time": now_iso(),
+                "system": system.name,
+                "path": str(system.path),
+                "action": "baseline_created",
+            },
+        )
+        print(f"Baseline captured for {system.name} ({system.path})")
+    return 0
+
+
+def cmd_scan(args: argparse.Namespace) -> int:
+    cfg = load_config(args.config)
+    incidents = scan_once(cfg, args.state_dir, repair=args.repair)
+    if incidents:
+        print(f"Detected {incidents} incident(s).")
+        return 2
+    print("No incidents detected.")
+    return 0
+
+
+def cmd_daemon(args: argparse.Namespace) -> int:
+    cfg = load_config(args.config)
+    print(f"Starting guard daemon loop every {cfg.poll_interval_seconds}s")
+    while True:
+        scan_once(cfg, args.state_dir, repair=True)
+        time.sleep(cfg.poll_interval_seconds)
+
+
+def cmd_restore(args: argparse.Namespace) -> int:
+    cfg = load_config(args.config)
+    names = {sys_cfg.name: sys_cfg for sys_cfg in cfg.systems}
+    if args.system not in names:
+        print(f"Unknown system '{args.system}'. Available: {', '.join(sorted(names))}", file=sys.stderr)
+        return 1
+
+    restore_from_snapshot(names[args.system], args.state_dir)
+    write_audit(
+        args.state_dir,
+        {
+            "time": now_iso(),
+            "system": args.system,
+            "path": str(names[args.system].path),
+            "action": "manual_restore",
+        },
+    )
+    print(f"Restored system from baseline snapshot: {args.system}")
+    return 0
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        description=(
+            "Protect your own systems by detecting unauthorized changes and "
+            "restoring trusted baselines."
+        )
+    )
+    parser.add_argument("--config", type=pathlib.Path, default=DEFAULT_CONFIG)
+    parser.add_argument("--state-dir", type=pathlib.Path, default=DEFAULT_STATE)
+
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    init_cfg = sub.add_parser("init-config", help="Create a starter config file")
+    init_cfg.add_argument("--force", action="store_true", help="Overwrite existing config")
+    init_cfg.set_defaults(func=cmd_init_config)
+
+    baseline = sub.add_parser("init-baseline", help="Capture trusted baselines")
+    baseline.set_defaults(func=cmd_init_baseline)
+
+    scan = sub.add_parser("scan", help="Run one drift scan")
+    scan.add_argument("--repair", action="store_true", help="Auto-restore if drift is found")
+    scan.set_defaults(func=cmd_scan)
+
+    daemon = sub.add_parser("daemon", help="Run continuous monitor loop with auto-repair")
+    daemon.set_defaults(func=cmd_daemon)
+
+    restore = sub.add_parser("restore", help="Manually restore one configured system")
+    restore.add_argument("system", help="System name from config")
+    restore.set_defaults(func=cmd_restore)
+
+    return parser
+
+
+def main() -> int:
+    parser = build_parser()
+    args = parser.parse_args()
+    return args.func(args)
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
