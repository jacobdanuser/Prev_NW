+#!/usr/bin/env python3
+"""Safely rewrite a local project's folder/file structure.
+
+This script is for *your own repository* layout migrations (e.g., Codex-like project refactors).
+It does not access or modify any hosted ChatGPT/OpenAI internal systems.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import shutil
+from pathlib import Path
+
+
+def load_plan(path: Path) -> dict[str, str]:
+    data = json.loads(path.read_text(encoding="utf-8"))
+    if not isinstance(data, dict) or not data:
+        raise ValueError("Plan must be a non-empty JSON object: {\"old/path\": \"new/path\"}")
+    return {str(k): str(v) for k, v in data.items()}
+
+
+def ensure_safe_relative(path_text: str) -> Path:
+    p = Path(path_text)
+    if p.is_absolute() or ".." in p.parts:
+        raise ValueError(f"Unsafe path '{path_text}'. Use repo-relative paths without '..'.")
+    return p
+
+
+def rewrite_structure(repo_root: Path, mapping: dict[str, str], dry_run: bool) -> list[tuple[Path, Path]]:
+    planned: list[tuple[Path, Path]] = []
+
+    for old, new in mapping.items():
+        src_rel = ensure_safe_relative(old)
+        dst_rel = ensure_safe_relative(new)
+        src = repo_root / src_rel
+        dst = repo_root / dst_rel
+
+        if not src.exists():
+            raise FileNotFoundError(f"Source does not exist: {src_rel}")
+        if dst.exists():
+            raise FileExistsError(f"Destination already exists: {dst_rel}")
+
+        planned.append((src, dst))
+
+    if dry_run:
+        return planned
+
+    for src, dst in planned:
+        dst.parent.mkdir(parents=True, exist_ok=True)
+        shutil.move(str(src), str(dst))
+
+    return planned
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description="Rewrite a local repo structure from a JSON mapping plan.")
+    parser.add_argument("--repo", default=".", help="Path to the repository root (default: current dir)")
+    parser.add_argument("--plan", required=True, help="JSON file path mapping old->new relative paths")
+    parser.add_argument("--dry-run", action="store_true", help="Print planned moves without modifying files")
+    args = parser.parse_args()
+
+    repo_root = Path(args.repo).resolve()
+    plan_path = Path(args.plan).resolve()
+
+    mapping = load_plan(plan_path)
+    moved = rewrite_structure(repo_root, mapping, dry_run=args.dry_run)
+
+    mode = "DRY-RUN" if args.dry_run else "APPLIED"
+    print(f"{mode}: {len(moved)} move(s)")
+    for src, dst in moved:
+        print(f" - {src.relative_to(repo_root)} -> {dst.relative_to(repo_root)}")
+
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
