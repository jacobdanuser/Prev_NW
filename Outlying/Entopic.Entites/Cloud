        print(f"{C_INFO}Remediation:{C_RESET}")
        for r in c.remediation:
            print(f"  → {r}")

        print(f"{C_INFO}Legal/Compliance Notes:{C_RESET}")
        for l in c.legal_considerations:
            print(f"  ⚖ {l}")

    section("PRIORITIZED ACTION PLAN")
    priorities = sorted(
        report.checks,
        key=lambda x: {"CRITICAL": 4, "HIGH": 3, "MEDIUM": 2, "LOW": 1}.get(x.severity.upper(), 0),
        reverse=True
    )
    for c in priorities:
        if c.status in ("FAIL", "WARN"):
            print(f"  [{c.severity}] {c.id}: {c.title}")

def export_json(report: AssessmentReport, path: str):
    payload = {
        "org_name": report.org_name,
        "environment": report.environment,
        "assessor": report.assessor,
        "timestamp": report.timestamp,
        "summary": report.summary,
        "legal_ethics_statement": report.legal_ethics_statement,
        "checks": [c.__dict__ for c in report.checks],
    }
    with open(path, "w", encoding="utf-8") as f:
        json.dump(payload, f, indent=2)
    print(f"\n{C_PASS}[OK]{C_RESET} JSON report exported to: {path}")

