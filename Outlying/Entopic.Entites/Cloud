def print_report(report: AssessmentReport):
    banner("ETHICAL CLOUD SECURITY & GOVERNANCE ASSESSMENT")
    label("Organization", report.org_name)
    label("Environment", report.environment)
    label("Assessor", report.assessor)
    label("Timestamp (UTC)", report.timestamp)

    section("LEGAL & ETHICAL STATEMENT")
    print(f"{C_INFO}{report.legal_ethics_statement}{C_RESET}")

    section("EXECUTIVE SUMMARY")
    for k in ["PASS", "WARN", "FAIL", "INFO"]:
        print(f"  - {k:<5}: {report.summary.get(k, 0)}")

    section("DETAILED FINDINGS")
    for i, c in enumerate(report.checks, start=1):
        print(f"\n{C_LABEL}Finding {i}: {c.id} - {c.title}{C_RESET}")
        label("Category", c.category)
        label("Status", status_colored(c.status))
        label("Severity", c.severity)
        print(f"{C_INFO}Description{C_RESET}: {c.description}")

        print(f"{C_INFO}Evidence:{C_RESET}")
        for e in c.evidence:
