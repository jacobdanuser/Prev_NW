+#!/usr/bin/env python3
+"""Safely migrate a Codex-style JSON config to a normalized structure.
+
+This script is intentionally defensive: it only rewrites known keys and preserves
+unknown keys. It can run in --dry-run mode to preview changes.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+from copy import deepcopy
+from pathlib import Path
+from typing import Any, Dict, List, Tuple
+
+
+def migrate_config(data: Dict[str, Any]) -> Tuple[Dict[str, Any], List[str]]:
+    """Return migrated config and a list of human-readable change notes."""
+    result = deepcopy(data)
+    notes: List[str] = []
+
+    # 1) Move top-level `models` and `routing` under `engine`.
+    engine = result.setdefault("engine", {})
+    if "models" in result and "models" not in engine:
+        engine["models"] = result.pop("models")
+        notes.append("Moved `models` -> `engine.models`")
+
+    if "routing" in result and "routing" not in engine:
+        engine["routing"] = result.pop("routing")
+        notes.append("Moved `routing` -> `engine.routing`")
+
+    # 2) Normalize provider fields.
+    providers = result.get("providers")
+    if isinstance(providers, list):
+        for idx, provider in enumerate(providers):
+            if not isinstance(provider, dict):
+                continue
+
+            if "apiKey" in provider and "api_key" not in provider:
+                provider["api_key"] = provider.pop("apiKey")
+                notes.append(f"Provider[{idx}] renamed `apiKey` -> `api_key`")
+
+            if "baseUrl" in provider and "base_url" not in provider:
+                provider["base_url"] = provider.pop("baseUrl")
+                notes.append(f"Provider[{idx}] renamed `baseUrl` -> `base_url`")
+
+    # 3) Normalize feature flags as booleans.
+    features = result.get("features")
+    if isinstance(features, dict):
+        for key, value in list(features.items()):
+            if isinstance(value, str):
+                lowered = value.strip().lower()
+                if lowered in {"on", "enabled", "true", "1"}:
+                    features[key] = True
+                    notes.append(f"Feature `{key}` normalized to boolean True")
+                elif lowered in {"off", "disabled", "false", "0"}:
+                    features[key] = False
+                    notes.append(f"Feature `{key}` normalized to boolean False")
+
+    return result, notes
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description="Migrate a Codex-style JSON config.")
+    parser.add_argument("input", type=Path, help="Path to input JSON config")
+    parser.add_argument("-o", "--output", type=Path, help="Output file path (default: overwrite input)")
+    parser.add_argument("--dry-run", action="store_true", help="Preview migration without writing file")
+    args = parser.parse_args()
+
+    raw = args.input.read_text(encoding="utf-8")
+    data = json.loads(raw)
+    if not isinstance(data, dict):
+        raise SystemExit("Input JSON must be an object at the top level.")
+
+    migrated, notes = migrate_config(data)
+
+    if args.dry_run:
+        print(json.dumps(migrated, indent=2, ensure_ascii=False))
+        print("\nChanges:")
+        if notes:
+            for note in notes:
+                print(f"- {note}")
+        else:
+            print("- No changes needed")
+        return 0
+
+    output_path = args.output or args.input
+    output_path.write_text(json.dumps(migrated, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
+
+    if notes:
+        print("Applied migration:")
+        for note in notes:
+            print(f"- {note}")
+    else:
+        print("No changes needed")
+
+    print(f"Wrote: {output_path}")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
