+#!/usr/bin/env python3
+"""
+System Change Rewriter (defensive rollback tool)
+
+Purpose
+-------
+Detect and automatically roll back unauthorized file changes for protected paths,
+including changes introduced via `git` workflows (e.g., compromised GitHub token,
+malicious pull) or local automation tools.
+
+How it works
+------------
+1. `init` command creates a signed baseline manifest of expected file hashes.
+2. `check` command compares live files to the baseline.
+3. If drift is detected and `--rewrite` is enabled:
+   - For git repos: perform hard reset to trusted ref + clean untracked files.
+   - For non-git paths: restore files from snapshot directory.
+4. Optional `watch` mode runs checks continuously.
+
+Important
+---------
+- This is a safety/defense utility for your own systems.
+- Run as a user with permissions only for the paths you own.
+- Review configuration carefully before enabling automatic rewrite.
+"""
+
+from __future__ import annotations
+
+import argparse
+import dataclasses
+import hashlib
+import hmac
+import json
+import os
+import shutil
+import signal
+import subprocess
+import sys
+import time
+from pathlib import Path
+from typing import Dict, Iterable, List, Optional, Tuple
+
+DEFAULT_BASELINE = ".system_guard_baseline.json"
+DEFAULT_SNAPSHOT_DIR = ".system_guard_snapshot"
+
+
+@dataclasses.dataclass
+class ProtectedPath:
+    path: Path
+    mode: str  # "git" | "snapshot"
+    trusted_ref: str = "HEAD"
+
+
+@dataclasses.dataclass
+class Change:
+    path: str
+    reason: str
+
+
+@dataclasses.dataclass
+class Baseline:
+    version: int
+    created_at: float
+    paths: List[Dict[str, str]]
+    files: Dict[str, str]
+    signature: str
+
+
+class GuardError(RuntimeError):
+    pass
+
+
+def sha256_file(path: Path) -> str:
+    h = hashlib.sha256()
+    with path.open("rb") as f:
+        for chunk in iter(lambda: f.read(1024 * 1024), b""):
+            h.update(chunk)
+    return h.hexdigest()
+
+
+def normalize_relative(path: Path, root: Path) -> str:
+    return str(path.resolve().relative_to(root.resolve())).replace("\\", "/")
+
+
+def walk_files(root: Path, ignored_names: Iterable[str]) -> Iterable[Path]:
+    ignored = set(ignored_names)
+    for dirpath, dirnames, filenames in os.walk(root):
+        dirnames[:] = [d for d in dirnames if d not in ignored]
+        for name in filenames:
+            if name in ignored:
+                continue
+            p = Path(dirpath) / name
+            if p.is_symlink():
+                continue
+            yield p
+
+
+def is_git_repo(path: Path) -> bool:
+    return (path / ".git").exists()
+
+
+def run(cmd: List[str], cwd: Optional[Path] = None) -> Tuple[int, str, str]:
+    proc = subprocess.run(
+        cmd,
+        cwd=str(cwd) if cwd else None,
+        capture_output=True,
+        text=True,
+    )
+    return proc.returncode, proc.stdout.strip(), proc.stderr.strip()
+
+
+def get_manifest_signature(payload: Dict, secret: str) -> str:
+    body = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
+    return hmac.new(secret.encode("utf-8"), body, hashlib.sha256).hexdigest()
+
+
+def build_file_hashes(paths: List[ProtectedPath], ignored_names: Iterable[str]) -> Dict[str, str]:
+    hashes: Dict[str, str] = {}
+    for protected in paths:
+        base = protected.path.resolve()
+        if not base.exists():
+            raise GuardError(f"Protected path does not exist: {base}")
+
+        for f in walk_files(base, ignored_names):
+            key = f"{base}::{normalize_relative(f, base)}"
+            hashes[key] = sha256_file(f)
+    return hashes
+
+
+def parse_paths(raw: List[str]) -> List[ProtectedPath]:
+    result: List[ProtectedPath] = []
+    for item in raw:
+        # Syntax:
+        #   /path/to/protected
+        #   /path/to/protected:git:main
+        #   /path/to/protected:snapshot
+        parts = item.split(":")
+        p = Path(parts[0]).expanduser().resolve()
+
+        mode = "git" if is_git_repo(p) else "snapshot"
+        ref = "HEAD"
+
+        if len(parts) >= 2 and parts[1]:
+            mode = parts[1]
+        if len(parts) >= 3 and parts[2]:
+            ref = parts[2]
+
+        if mode not in {"git", "snapshot"}:
+            raise GuardError(f"Invalid mode for {item!r}. Use git|snapshot")
+
+        result.append(ProtectedPath(path=p, mode=mode, trusted_ref=ref))
+    return result
+
+
+def save_baseline(path: Path, baseline: Baseline) -> None:
+    path.write_text(json.dumps(dataclasses.asdict(baseline), indent=2) + "\n", encoding="utf-8")
+
+
+def load_baseline(path: Path) -> Baseline:
+    if not path.exists():
+        raise GuardError(f"Baseline file not found: {path}")
+    data = json.loads(path.read_text(encoding="utf-8"))
+    return Baseline(
+        version=int(data["version"]),
+        created_at=float(data["created_at"]),
+        paths=list(data["paths"]),
+        files=dict(data["files"]),
+        signature=str(data["signature"]),
+    )
+
+
+def init_baseline(
+    baseline_file: Path,
+    snapshot_dir: Path,
+    secret: str,
+    protected: List[ProtectedPath],
+    ignored_names: Iterable[str],
+) -> None:
+    hashes = build_file_hashes(protected, ignored_names)
+    path_items = [
+        {"path": str(p.path), "mode": p.mode, "trusted_ref": p.trusted_ref}
+        for p in protected
+    ]
+
+    payload = {
+        "version": 1,
+        "created_at": time.time(),
+        "paths": path_items,
+        "files": hashes,
+    }
+    signature = get_manifest_signature(payload, secret)
+    baseline = Baseline(signature=signature, **payload)
+    save_baseline(baseline_file, baseline)
+
+    # Snapshot only for paths marked snapshot.
+    if snapshot_dir.exists():
+        shutil.rmtree(snapshot_dir)
+    snapshot_dir.mkdir(parents=True, exist_ok=True)
+
+    for p in protected:
+        if p.mode != "snapshot":
+            continue
+        dest = snapshot_dir / p.path.name
+        shutil.copytree(p.path, dest)
+
+    print(f"Baseline initialized: {baseline_file}")
+    print(f"Snapshot directory:   {snapshot_dir}")
+
+
+def verify_signature(baseline: Baseline, secret: str) -> None:
+    payload = {
+        "version": baseline.version,
+        "created_at": baseline.created_at,
+        "paths": baseline.paths,
+        "files": baseline.files,
+    }
+    expected = get_manifest_signature(payload, secret)
+    if not hmac.compare_digest(expected, baseline.signature):
+        raise GuardError("Baseline signature mismatch. Manifest may be tampered.")
+
+
+def detect_changes(
+    baseline: Baseline,
+    ignored_names: Iterable[str],
+) -> Tuple[List[ProtectedPath], List[Change]]:
+    protected = [
+        ProtectedPath(path=Path(x["path"]), mode=x["mode"], trusted_ref=x.get("trusted_ref", "HEAD"))
+        for x in baseline.paths
+    ]
+    current_hashes = build_file_hashes(protected, ignored_names)
+
+    changes: List[Change] = []
+    expected_keys = set(baseline.files.keys())
+    current_keys = set(current_hashes.keys())
+
+    for added in sorted(current_keys - expected_keys):
+        changes.append(Change(path=added, reason="unexpected_file_added"))
+
+    for removed in sorted(expected_keys - current_keys):
+        changes.append(Change(path=removed, reason="expected_file_missing"))
+
+    for shared in sorted(current_keys & expected_keys):
+        if current_hashes[shared] != baseline.files[shared]:
+            changes.append(Change(path=shared, reason="hash_changed"))
+
+    return protected, changes
+
+
+def rewrite_git(path: Path, trusted_ref: str) -> None:
+    rc, _, err = run(["git", "rev-parse", "--is-inside-work-tree"], cwd=path)
+    if rc != 0:
+        raise GuardError(f"Not a git repo: {path} ({err})")
+
+    rc, _, err = run(["git", "fetch", "--all", "--prune"], cwd=path)
+    if rc != 0:
+        print(f"Warning: git fetch failed for {path}: {err}", file=sys.stderr)
+
+    for cmd in (
+        ["git", "reset", "--hard", trusted_ref],
+        ["git", "clean", "-fd"],
+    ):
+        rc, _, err = run(cmd, cwd=path)
+        if rc != 0:
+            raise GuardError(f"Rewrite failed in {path}: {' '.join(cmd)} :: {err}")
+
+
+def rewrite_snapshot(path: Path, snapshot_dir: Path) -> None:
+    snap = snapshot_dir / path.name
+    if not snap.exists():
+        raise GuardError(f"Snapshot not found for {path}: {snap}")
+
+    if path.exists():
+        shutil.rmtree(path)
+    shutil.copytree(snap, path)
+
+
+def rewrite_changes(protected_paths: List[ProtectedPath], snapshot_dir: Path) -> None:
+    for p in protected_paths:
+        if p.mode == "git":
+            rewrite_git(p.path, p.trusted_ref)
+        else:
+            rewrite_snapshot(p.path, snapshot_dir)
+
+
+def print_changes(changes: List[Change]) -> None:
+    if not changes:
+        print("No unauthorized changes detected.")
+        return
+
+    print("Detected unauthorized changes:")
+    for c in changes:
+        print(f" - {c.reason}: {c.path}")
+
+
+def build_parser() -> argparse.ArgumentParser:
+    p = argparse.ArgumentParser(description="Detect and rewrite unauthorized system changes.")
+    p.add_argument("--baseline", default=DEFAULT_BASELINE, help="Path to baseline JSON")
+    p.add_argument("--snapshot-dir", default=DEFAULT_SNAPSHOT_DIR, help="Path to snapshot root")
+    p.add_argument(
+        "--hmac-secret-env",
+        default="SYSTEM_GUARD_HMAC_SECRET",
+        help="Environment variable holding HMAC secret",
+    )
+    p.add_argument(
+        "--ignore-name",
+        action="append",
+        default=[".git", "__pycache__", ".DS_Store"],
+        help="File/dir names to ignore (repeatable)",
+    )
+
+    sub = p.add_subparsers(dest="cmd", required=True)
+
+    init = sub.add_parser("init", help="Initialize baseline and snapshots")
+    init.add_argument(
+        "--protect",
+        nargs="+",
+        required=True,
+        help="Protected path specs: /path OR /path:git:main OR /path:snapshot",
+    )
+
+    check = sub.add_parser("check", help="Check for unauthorized changes")
+    check.add_argument("--rewrite", action="store_true", help="Rewrite changes when detected")
+
+    watch = sub.add_parser("watch", help="Continuously check and rewrite if configured")
+    watch.add_argument("--interval", type=int, default=30, help="Seconds between checks")
+    watch.add_argument("--rewrite", action="store_true", help="Rewrite changes when detected")
+
+    return p
+
+
+def get_secret(env_name: str) -> str:
+    secret = os.getenv(env_name)
+    if not secret:
+        raise GuardError(
+            f"Missing HMAC secret in env var {env_name}. "
+            "Set it before running to protect baseline integrity."
+        )
+    return secret
+
+
+def run_check(baseline_file: Path, snapshot_dir: Path, ignored: List[str], secret: str, rewrite: bool) -> int:
+    baseline = load_baseline(baseline_file)
+    verify_signature(baseline, secret)
+    protected, changes = detect_changes(baseline, ignored)
+    print_changes(changes)
+
+    if not changes:
+        return 0
+
+    if rewrite:
+        print("Rewriting unauthorized changes...")
+        rewrite_changes(protected, snapshot_dir)
+        print("Rewrite complete.")
+        return 2
+
+    return 1
+
+
+def main() -> int:
+    parser = build_parser()
+    args = parser.parse_args()
+
+    baseline_file = Path(args.baseline).expanduser().resolve()
+    snapshot_dir = Path(args.snapshot_dir).expanduser().resolve()
+    secret = get_secret(args.hmac_secret_env)
+
+    if args.cmd == "init":
+        protected = parse_paths(args.protect)
+        init_baseline(baseline_file, snapshot_dir, secret, protected, args.ignore_name)
+        return 0
+
+    if args.cmd == "check":
+        return run_check(baseline_file, snapshot_dir, args.ignore_name, secret, args.rewrite)
+
+    if args.cmd == "watch":
+        stop = False
+
+        def _stop(_signum, _frame):
+            nonlocal stop
+            stop = True
+
+        signal.signal(signal.SIGINT, _stop)
+        signal.signal(signal.SIGTERM, _stop)
+
+        while not stop:
+            code = run_check(baseline_file, snapshot_dir, args.ignore_name, secret, args.rewrite)
+            if code == 0:
+                print("[watch] state clean")
+            elif code == 1:
+                print("[watch] drift detected (rewrite disabled)")
+            else:
+                print("[watch] drift detected and rewritten")
+            time.sleep(max(1, int(args.interval)))
+
+        print("Watch mode stopped.")
+        return 0
+
+    raise GuardError(f"Unsupported command: {args.cmd}")
+
+
+if __name__ == "__main__":
+    try:
+        raise SystemExit(main())
+    except GuardError as e:
+        print(f"ERROR: {e}", file=sys.stderr)
+        raise SystemExit(2)
