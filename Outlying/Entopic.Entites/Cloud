+def run_scan(provider: str) -> List[Finding]:
+    checks = [
+        ControlCheck("IAM", "IAM-001", "MFA enforcement", check_iam_mfa),
+        ControlCheck("Data Protection", "DATA-002", "Public storage exposure", check_public_storage),
+        ControlCheck("Data Protection", "DATA-001", "Encryption at rest", check_encryption_at_rest),
+        ControlCheck("Monitoring", "MON-001", "Centralized logging", check_logging),
+        ControlCheck("Network", "NET-001", "Ingress exposure", check_network_exposure),
+    ]
+
+    data = load_provider_data(provider)
+    findings: List[Finding] = []
+
+    stage("[1/4] Initializing Benevolent Cloud Guard")
+    line("Purpose: authorized, defensive cloud posture visibility.")
+
+    stage("[2/4] Running labeled control checks")
+    for check in checks:
+        finding = check.run(data)
+        findings.append(finding)
+        color = severity_color(finding.severity)
+        print(
+            f"{color}[{finding.control_area}] {finding.control_id} | {finding.status:<4} | "
+            f"{finding.severity:<6} | {finding.title}{Color.RESET}"
+        )
+
+    stage("[3/4] Building compliance summary")
+    return findings
+
+
+def summarize(findings: List[Finding]) -> Dict[str, int]:
+    summary = {"HIGH": 0, "MEDIUM": 0, "LOW": 0, "PASS": 0, "FAIL": 0}
+    for f in findings:
+        summary[f.severity.upper()] += 1
+        summary[f.status.upper()] += 1
+    return summary
+
+
+def write_report(provider: str, findings: List[Finding], output_path: Path) -> None:
+    output_path.parent.mkdir(parents=True, exist_ok=True)
+    summary = summarize(findings)
+    report = {
+        "provider": provider,
+        "generated_at": datetime.now(timezone.utc).isoformat(),
+        "legal_notice": (
+            "Authorized defensive assessment only. Do not use for unauthorized access, "
+            "control bypass, or disruptive activity."
+        ),
+        "findings": [asdict(f) for f in findings],
+        "summary": summary,
+    }
+    output_path.write_text(json.dumps(report, indent=2), encoding="utf-8")
+
+    stage("[4/4] Report completed")
+    line(f"Saved JSON report: {output_path}")
+    line(
+        "Summary: "
+        + ", ".join(f"{k}={v}" for k, v in summary.items())
+    )
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description="Benevolent Cloud Guard")
+    parser.add_argument(
+        "--provider",
+        choices=["sample", "aws", "azure", "gcp"],
+        default="sample",
+        help="Cloud provider context. Non-sample modes currently use safe placeholder data.",
+    )
+    parser.add_argument(
+        "--output",
+        default="reports/cloud_guard_report.json",
+        help="Path for JSON report output.",
+    )
+    return parser.parse_args()
+
+
+def main() -> None:
+    args = parse_args()
+    findings = run_scan(args.provider)
+    write_report(args.provider, findings, Path(args.output))
+
+
+if __name__ == "__main__":
+    main()
