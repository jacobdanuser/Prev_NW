+#!/usr/bin/env python3
+"""System Rewrite Guard
+
+A defensive utility to automatically restore local systems to a trusted state
+when unauthorized changes are detected in Git repositories or plain files.
+
+Core ideas:
+1. Define "systems" as directories you own.
+2. Capture a trusted baseline snapshot per system.
+3. Continuously scan for drift.
+4. Restore unauthorized changes automatically.
+5. Record every detection and remediation event in an audit log.
+
+This tool is intentionally local-first and owner-centric: it is designed to protect
+systems that belong to the operator running the tool.
+"""
+
+from __future__ import annotations
+
+import argparse
+import dataclasses
+import datetime as dt
+import hashlib
+import json
+import os
+import pathlib
+import shutil
+import subprocess
+import sys
+import tarfile
+import tempfile
+import time
+from typing import Iterable
+
+
+DEFAULT_CONFIG = pathlib.Path.home() / ".config" / "system_rewrite_guard" / "config.json"
+DEFAULT_STATE = pathlib.Path.home() / ".local" / "state" / "system_rewrite_guard"
+
+
+@dataclasses.dataclass
+class ManagedSystem:
+    """Configuration for a single protected system path."""
+
+    name: str
+    path: pathlib.Path
+    include_hidden: bool = False
+
+
+@dataclasses.dataclass
+class GuardConfig:
+    """Global configuration for the guard service."""
+
+    owner: str
+    owner_emails: set[str]
+    require_signed_commits: bool
+    allowed_remotes: set[str]
+    ignore_globs: list[str]
+    systems: list[ManagedSystem]
+    poll_interval_seconds: int = 20
+
+    @staticmethod
+    def from_dict(payload: dict) -> "GuardConfig":
+        systems = [
+            ManagedSystem(
+                name=entry["name"],
+                path=pathlib.Path(entry["path"]).expanduser().resolve(),
+                include_hidden=entry.get("include_hidden", False),
+            )
+            for entry in payload["systems"]
+        ]
+        return GuardConfig(
+            owner=payload["owner"],
+            owner_emails=set(payload.get("owner_emails", [])),
+            require_signed_commits=payload.get("require_signed_commits", False),
+            allowed_remotes=set(payload.get("allowed_remotes", [])),
+            ignore_globs=payload.get("ignore_globs", []),
+            systems=systems,
+            poll_interval_seconds=payload.get("poll_interval_seconds", 20),
+        )
+
+
+def run(cmd: list[str], cwd: pathlib.Path | None = None) -> subprocess.CompletedProcess:
+    return subprocess.run(cmd, cwd=str(cwd) if cwd else None, capture_output=True, text=True)
+
+
+def now_iso() -> str:
+    return dt.datetime.now(dt.timezone.utc).isoformat()
+
+
+def load_config(config_path: pathlib.Path) -> GuardConfig:
+    payload = json.loads(config_path.read_text())
+    cfg = GuardConfig.from_dict(payload)
+    missing = [s.path for s in cfg.systems if not s.path.exists()]
+    if missing:
+        raise FileNotFoundError(f"Configured system paths do not exist: {missing}")
+    return cfg
+
+
+def state_paths(state_dir: pathlib.Path, system: ManagedSystem) -> tuple[pathlib.Path, pathlib.Path]:
+    base_dir = state_dir / system.name
+    return base_dir / "baseline_manifest.json", base_dir / "baseline_snapshot.tar.gz"
+
+
+def should_ignore(path: pathlib.Path, root: pathlib.Path, globs: Iterable[str]) -> bool:
+    rel = path.relative_to(root)
+    for glob in globs:
+        if rel.match(glob):
+            return True
+    return False
+
+
+def hash_file(path: pathlib.Path) -> str:
+    digest = hashlib.sha256()
+    with path.open("rb") as handle:
+        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
+            digest.update(chunk)
+    return digest.hexdigest()
+
+
+def build_manifest(root: pathlib.Path, ignore_globs: Iterable[str], include_hidden: bool) -> dict[str, dict]:
+    manifest: dict[str, dict] = {}
+    for p in root.rglob("*"):
+        if p.is_dir():
+            continue
+        if not include_hidden and any(part.startswith(".") for part in p.relative_to(root).parts):
+            continue
+        if should_ignore(p, root, ignore_globs):
+            continue
+        stat = p.stat()
+        manifest[str(p.relative_to(root))] = {
+            "sha256": hash_file(p),
+            "size": stat.st_size,
+            "mtime": stat.st_mtime,
+        }
+    return manifest
+
+
+def write_audit(state_dir: pathlib.Path, event: dict) -> None:
+    state_dir.mkdir(parents=True, exist_ok=True)
+    audit = state_dir / "audit.log.jsonl"
+    with audit.open("a", encoding="utf-8") as handle:
+        handle.write(json.dumps(event, sort_keys=True) + "\n")
+
+
+def verify_repo_trust(repo_root: pathlib.Path, cfg: GuardConfig) -> tuple[bool, list[str]]:
+    reasons: list[str] = []
+
+    remote = run(["git", "remote", "get-url", "origin"], cwd=repo_root)
+    if remote.returncode == 0 and cfg.allowed_remotes:
+        remote_url = remote.stdout.strip()
+        if remote_url not in cfg.allowed_remotes:
+            reasons.append(f"origin remote not allow-listed: {remote_url}")
+
+    author = run(["git", "log", "-1", "--pretty=%ae"], cwd=repo_root)
+    if author.returncode != 0:
+        reasons.append("cannot inspect git author")
+    else:
+        author_email = author.stdout.strip()
+        if cfg.owner_emails and author_email not in cfg.owner_emails:
+            reasons.append(f"latest commit author not owner: {author_email}")
+
+    if cfg.require_signed_commits:
+        verify = run(["git", "verify-commit", "HEAD"], cwd=repo_root)
+        if verify.returncode != 0:
+            reasons.append("HEAD commit signature verification failed")
+
+    status = run(["git", "status", "--porcelain"], cwd=repo_root)
+    if status.returncode == 0 and status.stdout.strip():
+        reasons.append("working tree has uncommitted changes")
+
+    return len(reasons) == 0, reasons
+
