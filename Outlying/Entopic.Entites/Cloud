+#!/usr/bin/env python3
+"""Benevolent Cloud Governance Guard
+
+This script is intentionally defensive: it audits and labels cloud controls
+for systems you own and operate. It does not bypass security controls.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import re
+import sys
+from dataclasses import dataclass
+from enum import Enum
+from typing import Any
+
+
+class Color:
+    RESET = "\033[0m"
+    BOLD = "\033[1m"
+    RED = "\033[31m"
+    GREEN = "\033[32m"
+    YELLOW = "\033[33m"
+    BLUE = "\033[34m"
+    MAGENTA = "\033[35m"
+    CYAN = "\033[36m"
+
+
+class Severity(str, Enum):
+    INFO = "INFO"
+    LOW = "LOW"
+    MEDIUM = "MEDIUM"
+    HIGH = "HIGH"
+    CRITICAL = "CRITICAL"
+
+
+SEVERITY_COLORS = {
+    Severity.INFO: Color.CYAN,
+    Severity.LOW: Color.GREEN,
+    Severity.MEDIUM: Color.YELLOW,
+    Severity.HIGH: Color.MAGENTA,
+    Severity.CRITICAL: Color.RED,
+}
+
+
+@dataclass
+class Finding:
+    category: str
+    control: str
+    severity: Severity
+    status: str
+    evidence: str
+    remediation: str
+    legal_guidance: str
+
+
+def colorize(text: str, color: str, enabled: bool) -> str:
+    if not enabled:
+        return text
+    return f"{color}{text}{Color.RESET}"
+
+
+def is_truthy(value: Any) -> bool:
+    if isinstance(value, bool):
+        return value
+    if isinstance(value, str):
+        return value.strip().lower() in {"1", "true", "yes", "on", "enabled"}
+    if isinstance(value, (int, float)):
+        return value != 0
+    return bool(value)
+
+
+def evaluate_controls(cfg: dict[str, Any]) -> list[Finding]:
+    findings: list[Finding] = []
+
+    def add(category: str, control: str, ok: bool, severity: Severity, evidence: str, remediation: str):
+        findings.append(
+            Finding(
+                category=category,
+                control=control,
+                severity=severity if not ok else Severity.INFO,
+                status="PASS" if ok else "FAIL",
+                evidence=evidence,
+                remediation=remediation,
+                legal_guidance=(
+                    "Only audit and modify environments you are explicitly authorized to manage. "
+                    "Maintain change records and follow contractual + regulatory obligations."
+                ),
+            )
+        )
+
+    # IAM
+    iam = cfg.get("iam", {})
+    add(
+        "IAM",
+        "Multi-factor authentication required for admins",
+        is_truthy(iam.get("mfa_for_admins")),
+        Severity.CRITICAL,
+        f"mfa_for_admins={iam.get('mfa_for_admins')!r}",
+        "Require MFA for all human admin identities; block non-MFA console access.",
+    )
+    add(
+        "IAM",
+        "No wildcard admin policy attachments",
+        not is_truthy(iam.get("wildcard_admin_policies")),
+        Severity.HIGH,
+        f"wildcard_admin_policies={iam.get('wildcard_admin_policies')!r}",
+        "Replace wildcard policies with least-privilege scoped roles and policies.",
+    )
+
+    # Network
+    net = cfg.get("network", {})
+    add(
+        "Network",
+        "Public management ports closed (22/3389)",
+        not is_truthy(net.get("public_ssh_rdp_open")),
+        Severity.HIGH,
+        f"public_ssh_rdp_open={net.get('public_ssh_rdp_open')!r}",
+        "Disable public ingress to management ports; use bastion, VPN, or private access.",
+    )
+    add(
+        "Network",
+        "Default deny ingress posture",
+        is_truthy(net.get("default_deny_ingress")),
+        Severity.MEDIUM,
+        f"default_deny_ingress={net.get('default_deny_ingress')!r}",
+        "Apply default-deny security groups/firewalls and permit only documented flows.",
+    )
+
+    # Data protection
+    data = cfg.get("data", {})
+    add(
+        "Data",
+        "Encryption at rest enforced",
+        is_truthy(data.get("encryption_at_rest")),
+        Severity.HIGH,
+        f"encryption_at_rest={data.get('encryption_at_rest')!r}",
+        "Enable managed encryption keys for all storage/database services.",
+    )
+    add(
+        "Data",
+        "Encryption in transit enforced",
+        is_truthy(data.get("tls_everywhere")),
+        Severity.HIGH,
+        f"tls_everywhere={data.get('tls_everywhere')!r}",
+        "Require TLS for APIs, service mesh links, and admin endpoints.",
+    )
+
+    # Observability
+    obs = cfg.get("observability", {})
+    add(
+        "Observability",
+        "Centralized immutable audit logging",
+        is_truthy(obs.get("centralized_audit_logging")),
+        Severity.CRITICAL,
+        f"centralized_audit_logging={obs.get('centralized_audit_logging')!r}",
+        "Ship cloud audit logs to immutable storage with retention and alerting.",
+    )
+    add(
+        "Observability",
+        "Security alerting enabled",
+        is_truthy(obs.get("security_alerting")),
+        Severity.MEDIUM,
+        f"security_alerting={obs.get('security_alerting')!r}",
+        "Enable high-confidence detections and on-call notification workflows.",
+    )
+
+    return findings
+
+
+def print_report(findings: list[Finding], color: bool) -> None:
+    print(colorize("\n=== BENEVOLENT CLOUD GOVERNANCE REPORT ===", Color.BOLD + Color.BLUE, color))
+    print("Labeled controls with legal/ethical scope.\n")
+
+    for i, f in enumerate(findings, start=1):
+        sev_text = colorize(f.severity.value, SEVERITY_COLORS[f.severity], color)
+        status_color = Color.GREEN if f.status == "PASS" else Color.RED
+        status_text = colorize(f.status, status_color, color)
+
+        print(colorize(f"[{i:02d}] {f.category} :: {f.control}", Color.BOLD, color))
+        print(f"  Status     : {status_text}")
+        print(f"  Severity   : {sev_text}")
+        print(f"  Evidence   : {f.evidence}")
+        print(f"  Remediation: {f.remediation}")
+        print(f"  Legal Note : {f.legal_guidance}\n")
+
+    failed = [f for f in findings if f.status == "FAIL"]
+    print(colorize("=== SUMMARY ===", Color.BOLD + Color.CYAN, color))
+    print(f"Total controls : {len(findings)}")
+    print(colorize(f"Passed         : {len(findings) - len(failed)}", Color.GREEN, color))
+    print(colorize(f"Failed         : {len(failed)}", Color.RED if failed else Color.GREEN, color))
+
+
+def parse_input(path: str) -> dict[str, Any]:
+    if not os.path.exists(path):
+        raise FileNotFoundError(f"Input file not found: {path}")
+
+    with open(path, "r", encoding="utf-8") as f:
+        raw = f.read()
+
+    if path.endswith(".json"):
+        return json.loads(raw)
+
+    # very small YAML subset fallback without external dependency
+    cfg: dict[str, Any] = {}
+    current_section: str | None = None
+    for line in raw.splitlines():
+        if not line.strip() or line.strip().startswith("#"):
+            continue
+        if re.match(r"^[A-Za-z_][\w-]*:\s*$", line):
+            current_section = line.split(":", 1)[0].strip()
+            cfg[current_section] = {}
+            continue
+        if current_section and ":" in line:
+            k, v = line.strip().split(":", 1)
+            cfg[current_section][k.strip()] = v.strip().strip('"\'')
+    return cfg
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(
+        description="Defensive cloud governance audit with colored/labeled reporting."
+    )
+    parser.add_argument("--input", required=True, help="Path to JSON or simple YAML config file")
+    parser.add_argument("--no-color", action="store_true", help="Disable ANSI colors")
+    parser.add_argument("--fail-on-findings", action="store_true", help="Exit 2 when any controls fail")
+    args = parser.parse_args()
+
+    cfg = parse_input(args.input)
+    findings = evaluate_controls(cfg)
+    print_report(findings, color=not args.no_color)
+
+    if args.fail_on_findings and any(f.status == "FAIL" for f in findings):
+        return 2
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
