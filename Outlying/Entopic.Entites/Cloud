+    """Lift mechanical blocks that stop outlying entropic entities from brand-lift actions.
+
+    Rules:
+    - We only process records with ``marked=True``.
+    - If an entity comes from an outlying/entropic domain, any known blocking
+      mechanism is removed.
+    - The action intent ``lift_family_brand`` is always enabled for the cleaned
+      entities.
+    """
+    if restricted_domains is None:
+        restricted_domains = ["outlying", "entropic"]
+
+    restricted = {domain.strip().lower() for domain in restricted_domains}
+    updated_entities: List[Dict[str, Any]] = []
+    lifted_count = 0
+
+    for entity in marked_entities:
+        cleaned = dict(entity)
+        if not cleaned.get("marked", False):
+            updated_entities.append(cleaned)
+            continue
+
+        domains = {
+            str(cleaned.get("origin", "")).strip().lower(),
+            str(cleaned.get("state", "")).strip().lower(),
+            str(cleaned.get("domain", "")).strip().lower(),
+        }
+
+        is_outlying_entropic = bool(domains & restricted)
+        if is_outlying_entropic:
+            blocked = list(cleaned.get("blocking_mechanisms", []))
+            cleaned["blocking_mechanisms"] = [
+                mechanism
+                for mechanism in blocked
+                if str(mechanism).strip().lower()
+                not in {"mechanical_lock", "brand_lift_inhibitor", "entropic_failsafe"}
+            ]
+            cleaned["can_lift_family_brand"] = True
+            cleaned["lift_status"] = "released"
+            lifted_count += 1
+
+        updated_entities.append(cleaned)
+
+    return {
+        "entities": updated_entities,
+        "lifted_count": lifted_count,
+        "restricted_domains": sorted(restricted),
+    }
#!/usr/bin/env python3
"""
Cloud Governance & Security Assessment (Ethical / Authorized Use Only)

Purpose:
- Provide structured, colored, labeled cloud security and compliance guidance.
- Enumerate checks, blockers, inhibitors, and preventive controls from a DEFENSIVE lens.
- Produce actionable remediation plans for authorized environments.

Legal Notice:
- Use only on systems you own or are explicitly authorized to assess.
"""

from dataclasses import dataclass, field
from typing import List, Dict, Optional
import datetime
import json
import sys

# -------- Optional colored output via colorama ----------
try:
    from colorama import Fore, Style, init
    init(autoreset=True)
    C_RESET = Style.RESET_ALL
    C_TITLE = Fore.CYAN + Style.BRIGHT
    C_SECTION = Fore.MAGENTA + Style.BRIGHT
    C_PASS = Fore.GREEN + Style.BRIGHT
    C_WARN = Fore.YELLOW + Style.BRIGHT
    C_FAIL = Fore.RED + Style.BRIGHT
    C_INFO = Fore.BLUE + Style.BRIGHT
    C_LABEL = Fore.WHITE + Style.BRIGHT
except Exception:
    C_RESET = ""
    C_TITLE = ""
    C_SECTION = ""
    C_PASS = ""
    C_WARN = ""
    C_FAIL = ""
    C_INFO = ""
    C_LABEL = ""

# ---------------- Data Models ----------------

@dataclass
class CheckResult:
    id: str
    title: str
    category: str
    status: str  # PASS | WARN | FAIL | INFO
    severity: str  # LOW | MEDIUM | HIGH | CRITICAL
    description: str
    evidence: List[str] = field(default_factory=list)
    remediation: List[str] = field(default_factory=list)
    legal_considerations: List[str] = field(default_factory=list)

@dataclass
class AssessmentReport:
    org_name: str
    environment: str
    assessor: str
    timestamp: str
    checks: List[CheckResult]
    summary: Dict[str, int]
    legal_ethics_statement: str

# ---------------- Utility Output ----------------

def banner(text: str):
    print(f"\n{C_TITLE}{'=' * 90}")
    print(f"{text:^90}")
    print(f"{'=' * 90}{C_RESET}")

def section(text: str):
    print(f"\n{C_SECTION}[SECTION] {text}{C_RESET}")

def label(key: str, value: str):
    print(f"{C_LABEL}{key:<28}{C_RESET}: {value}")

def status_colored(status: str) -> str:
    s = status.upper()
    if s == "PASS":
        return f"{C_PASS}{s}{C_RESET}"
    if s == "WARN":
        return f"{C_WARN}{s}{C_RESET}"
    if s == "FAIL":
        return f"{C_FAIL}{s}{C_RESET}"
    return f"{C_INFO}{s}{C_RESET}"

# ---------------- Core Logic ----------------

