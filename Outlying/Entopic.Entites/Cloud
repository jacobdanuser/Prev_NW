+#!/usr/bin/env python3
+"""
+System Rewrite Guard
+====================
+
+Defensive utility to automatically detect and rewrite unauthorized repository
+changes (local/uncommitted and committed history) based on a strict policy.
+
+Designed for *your systems alone* by allowing host lock and owner lock.
+
+Capabilities:
+- Verify host + owner lock before doing anything.
+- Detect uncommitted modifications and optionally rewrite them.
+- Detect unauthorized commits since a trusted reference and rewrite to the last
+  trusted commit.
+- Make forensic backups (patch + metadata) before rewrite.
+- Optional daemon mode for continuous enforcement.
+
+Usage examples:
+  python3 system_rewrite_guard.py init-policy
+  python3 system_rewrite_guard.py snapshot-baseline
+  python3 system_rewrite_guard.py enforce --rewrite
+  python3 system_rewrite_guard.py daemon --interval 60 --rewrite
+"""
+
+from __future__ import annotations
+
+import argparse
+import dataclasses
+import datetime as dt
+import getpass
+import hashlib
+import json
+import os
+import pathlib
+import platform
+import shlex
+import socket
+import subprocess
+import sys
+import time
+from typing import Iterable, List, Optional
+
+POLICY_FILE = ".rewrite_guard_policy.json"
+STATE_DIR = ".rewrite_guard"
+BASELINE_FILE = "baseline_hashes.json"
+EVENT_LOG_FILE = "events.log"
+
+
+class GuardError(RuntimeError):
+    pass
+
+
+def run(cmd: List[str], cwd: Optional[pathlib.Path] = None, check: bool = True) -> subprocess.CompletedProcess:
+    result = subprocess.run(
+        cmd,
+        cwd=str(cwd) if cwd else None,
+        text=True,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+    )
+    if check and result.returncode != 0:
+        raise GuardError(
+            f"Command failed ({result.returncode}): {shlex.join(cmd)}\n"
+            f"stdout:\n{result.stdout}\n"
+            f"stderr:\n{result.stderr}"
+        )
+    return result
+
+
+def now_utc() -> str:
+    return dt.datetime.now(dt.timezone.utc).isoformat()
+
+
+def sha256_file(path: pathlib.Path) -> str:
+    h = hashlib.sha256()
+    with path.open("rb") as f:
+        while chunk := f.read(1024 * 1024):
+            h.update(chunk)
+    return h.hexdigest()
+
+
+@dataclasses.dataclass
+class Policy:
+    owner_user: str
+    host_lock: List[str]
+    allowed_author_emails: List[str]
+    require_verified_signature: bool
+    trusted_ref: str
+    protected_branches: List[str]
+    rewrite_uncommitted: bool
+    rewrite_untracked: bool
+
+    @staticmethod
+    def load(repo: pathlib.Path) -> "Policy":
+        path = repo / POLICY_FILE
+        if not path.exists():
+            raise GuardError(
+                f"Policy file not found: {path}. Run `init-policy` first."
+            )
+        data = json.loads(path.read_text())
+        return Policy(**data)
+
+    def save(self, repo: pathlib.Path) -> None:
+        path = repo / POLICY_FILE
+        path.write_text(json.dumps(dataclasses.asdict(self), indent=2) + "\n")
+
+
+def ensure_repo(repo: pathlib.Path) -> None:
+    run(["git", "rev-parse", "--is-inside-work-tree"], cwd=repo)
+
+
+def ensure_state_dir(repo: pathlib.Path) -> pathlib.Path:
+    d = repo / STATE_DIR
+    d.mkdir(parents=True, exist_ok=True)
+    return d
+
+
+def append_event(repo: pathlib.Path, message: str) -> None:
+    state = ensure_state_dir(repo)
+    with (state / EVENT_LOG_FILE).open("a", encoding="utf-8") as f:
+        f.write(f"{now_utc()} {message}\n")
+
+
+def host_identity() -> tuple[str, str]:
+    return getpass.getuser(), socket.gethostname()
+
+
+def assert_host_owner_lock(policy: Policy) -> None:
+    user, host = host_identity()
+    if user != policy.owner_user:
+        raise GuardError(f"Owner lock failed. expected={policy.owner_user} actual={user}")
+    if policy.host_lock and host not in policy.host_lock:
+        raise GuardError(
+            f"Host lock failed. host={host} not in allowed={policy.host_lock}"
+        )
+
+
+def git_current_branch(repo: pathlib.Path) -> str:
+    return run(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=repo).stdout.strip()
+
+
+def git_status_porcelain(repo: pathlib.Path) -> List[str]:
+    out = run(["git", "status", "--porcelain"], cwd=repo).stdout
+    return [line for line in out.splitlines() if line.strip()]
+
+
+def git_log_since(repo: pathlib.Path, start_ref: str) -> List[str]:
+    out = run(["git", "rev-list", f"{start_ref}..HEAD"], cwd=repo).stdout
+    commits = [c for c in out.splitlines() if c.strip()]
+    commits.reverse()  # oldest -> newest
+    return commits
+
+
+def commit_author_email(repo: pathlib.Path, commit: str) -> str:
+    return run(["git", "show", "-s", "--format=%ae", commit], cwd=repo).stdout.strip()
+
+
+def commit_signature_status(repo: pathlib.Path, commit: str) -> str:
+    # %G? gives: G=good, B=bad, U=good unknown validity, N=none, etc.
+    return run(["git", "show", "-s", "--format=%G?", commit], cwd=repo).stdout.strip()
+
+
+def create_forensic_bundle(repo: pathlib.Path, reason: str) -> pathlib.Path:
+    state = ensure_state_dir(repo)
+    stamp = dt.datetime.now().strftime("%Y%m%d_%H%M%S")
+    target = state / f"forensic_{stamp}"
+    target.mkdir(parents=True, exist_ok=True)
+
+    (target / "reason.txt").write_text(reason + "\n", encoding="utf-8")
+    (target / "git_status.txt").write_text(
+        run(["git", "status", "--short", "--branch"], cwd=repo).stdout,
+        encoding="utf-8",
+    )
+    (target / "git_log_head.txt").write_text(
+        run(["git", "log", "--oneline", "-n", "30"], cwd=repo).stdout,
+        encoding="utf-8",
+    )
+
+    # Capture local diffs if any.
+    diff = run(["git", "diff"], cwd=repo, check=False).stdout
+    if diff.strip():
+        (target / "worktree.diff").write_text(diff, encoding="utf-8")
+
+    staged = run(["git", "diff", "--cached"], cwd=repo, check=False).stdout
+    if staged.strip():
+        (target / "staged.diff").write_text(staged, encoding="utf-8")
+
+    return target
+
+
+def rewrite_to_ref(repo: pathlib.Path, ref: str, rewrite_untracked: bool) -> None:
+    run(["git", "reset", "--hard", ref], cwd=repo)
+    if rewrite_untracked:
+        run(["git", "clean", "-fd"], cwd=repo)
+
+
+def snapshot_baseline(repo: pathlib.Path) -> pathlib.Path:
+    state = ensure_state_dir(repo)
+    baseline: dict[str, str] = {}
+    files = run(["git", "ls-files"], cwd=repo).stdout.splitlines()
+    for rel in files:
+        path = repo / rel
+        if path.is_file():
+            baseline[rel] = sha256_file(path)
+    out = state / BASELINE_FILE
+    out.write_text(json.dumps({"created_at": now_utc(), "hashes": baseline}, indent=2) + "\n")
+    return out
+
+
+def verify_baseline(repo: pathlib.Path) -> List[str]:
+    baseline_path = repo / STATE_DIR / BASELINE_FILE
+    if not baseline_path.exists():
+        raise GuardError("No baseline found. Run snapshot-baseline first.")
+
+    data = json.loads(baseline_path.read_text())
+    expected: dict[str, str] = data.get("hashes", {})
+    mismatches: List[str] = []
+    for rel, expected_hash in expected.items():
+        p = repo / rel
+        if not p.exists():
+            mismatches.append(f"missing:{rel}")
+            continue
+        actual_hash = sha256_file(p)
+        if actual_hash != expected_hash:
+            mismatches.append(f"changed:{rel}")
+    return mismatches
+
+
+def unauthorized_commits(repo: pathlib.Path, policy: Policy) -> List[str]:
+    bad: List[str] = []
+    commits = git_log_since(repo, policy.trusted_ref)
+    for c in commits:
+        email = commit_author_email(repo, c)
+        if email not in policy.allowed_author_emails:
+            bad.append(f"{c}:author={email}")
+            continue
+        if policy.require_verified_signature:
+            sig = commit_signature_status(repo, c)
+            if sig not in {"G", "U"}:
+                bad.append(f"{c}:signature={sig}")
+    return bad
+
+
+def enforce(repo: pathlib.Path, rewrite: bool) -> int:
+    ensure_repo(repo)
+    policy = Policy.load(repo)
+    assert_host_owner_lock(policy)
+
+    branch = git_current_branch(repo)
+    if branch not in policy.protected_branches:
+        msg = f"Branch '{branch}' not protected. Skipping enforcement."
+        append_event(repo, msg)
+        print(msg)
+        return 0
+
+    problems: List[str] = []
+
+    bad_commits = unauthorized_commits(repo, policy)
+    if bad_commits:
+        problems.extend([f"unauthorized_commit:{x}" for x in bad_commits])
+
+    dirty = git_status_porcelain(repo)
+    if dirty:
+        problems.append(f"uncommitted_changes:{len(dirty)}")
+
+    try:
+        mismatches = verify_baseline(repo)
+    except GuardError:
+        mismatches = []
+
+    if mismatches:
+        problems.extend([f"baseline_mismatch:{m}" for m in mismatches])
+
+    if not problems:
+        append_event(repo, "enforce: clean")
+        print("No unauthorized changes detected.")
+        return 0
+
+    reason = " | ".join(problems)
+    append_event(repo, f"enforce: detected {reason}")
+    print("Detected issues:")
+    for p in problems:
+        print(f"  - {p}")
+
+    if not rewrite:
+        print("Rewrite disabled. Exiting with non-zero status.")
+        return 2
+
+    bundle = create_forensic_bundle(repo, reason)
+    append_event(repo, f"forensic_bundle: {bundle}")
+
+    should_rewrite = bool(bad_commits)
+    if dirty and policy.rewrite_uncommitted:
+        should_rewrite = True
+    if mismatches:
+        should_rewrite = True
+
+    if should_rewrite:
+        rewrite_to_ref(repo, policy.trusted_ref, policy.rewrite_untracked)
+        append_event(repo, f"rewrite: reset_to={policy.trusted_ref}")
+        print(f"Rewrite completed. Repository reset to {policy.trusted_ref}")
+        return 1
+
+    print("Issues detected but policy prevented rewrite.")
+    return 3
+
+
+def daemon(repo: pathlib.Path, interval: int, rewrite: bool) -> int:
+    print(f"Starting rewrite guard daemon (interval={interval}s, rewrite={rewrite})")
+    while True:
+        try:
+            code = enforce(repo, rewrite=rewrite)
+            if code == 1:
+                print("Unauthorized changes were rewritten.")
+        except GuardError as e:
+            print(f"GuardError: {e}")
+        except Exception as e:  # pragma: no cover
+            print(f"Unexpected error: {e}")
+        time.sleep(interval)
+
+
+def init_policy(repo: pathlib.Path) -> pathlib.Path:
+    user, host = host_identity()
+    email = run(["git", "config", "user.email"], cwd=repo, check=False).stdout.strip()
+    policy = Policy(
+        owner_user=user,
+        host_lock=[host],
+        allowed_author_emails=[email] if email else [],
+        require_verified_signature=False,
+        trusted_ref="HEAD",
+        protected_branches=[git_current_branch(repo)],
+        rewrite_uncommitted=True,
+        rewrite_untracked=True,
+    )
+    policy.save(repo)
+    ensure_state_dir(repo)
+    return repo / POLICY_FILE
+
+
+def parse_args(argv: Iterable[str]) -> argparse.Namespace:
+    p = argparse.ArgumentParser(description="Rewrite unauthorized repo changes to trusted state")
+    sub = p.add_subparsers(dest="cmd", required=True)
+
+    sub.add_parser("init-policy", help="Create default policy locked to current user/host")
+    sub.add_parser("snapshot-baseline", help="Record SHA256 baseline of tracked files")
+    sub.add_parser("verify-baseline", help="Check current files against baseline")
+
+    enforce_p = sub.add_parser("enforce", help="Detect and optionally rewrite unauthorized changes")
+    enforce_p.add_argument("--rewrite", action="store_true", help="Apply rewrite/reset when violations are found")
+
+    daemon_p = sub.add_parser("daemon", help="Run continuous enforcement loop")
+    daemon_p.add_argument("--interval", type=int, default=60, help="Seconds between checks")
+    daemon_p.add_argument("--rewrite", action="store_true", help="Apply rewrite/reset when violations are found")
+
+    return p.parse_args(list(argv))
+
+
+def main(argv: Iterable[str]) -> int:
+    args = parse_args(argv)
+    repo = pathlib.Path.cwd()
+
+    if args.cmd == "init-policy":
+        ensure_repo(repo)
+        path = init_policy(repo)
+        print(f"Created policy: {path}")
+        return 0
+
+    if args.cmd == "snapshot-baseline":
+        ensure_repo(repo)
+        out = snapshot_baseline(repo)
+        print(f"Baseline snapshot saved to: {out}")
+        return 0
+
+    if args.cmd == "verify-baseline":
+        ensure_repo(repo)
+        mismatches = verify_baseline(repo)
+        if mismatches:
+            print("Baseline mismatches detected:")
+            for x in mismatches:
+                print(f"  - {x}")
+            return 2
+        print("Baseline is clean.")
+        return 0
+
+    if args.cmd == "enforce":
+        return enforce(repo, rewrite=args.rewrite)
+
+    if args.cmd == "daemon":
+        return daemon(repo, interval=args.interval, rewrite=args.rewrite)
+
+    raise GuardError(f"Unknown command: {args.cmd}")
+
+
+if __name__ == "__main__":
+    try:
+        raise SystemExit(main(sys.argv[1:]))
+    except GuardError as e:
+        print(f"ERROR: {e}", file=sys.stderr)
+        raise SystemExit(1)
